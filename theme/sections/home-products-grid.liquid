
<section class="ab-pgrid ps-pgrid-section">
  {% assign _pc_search = theme_data.product_card_search_icon_url | strip | default: 'https://files.easy-orders.net/1777960580107194333search%20icon%20for%20prduct%20cards%20.svg' %}
  {% assign _pc_ch1 = theme_data.product_card_choose_label | default: '' | strip %}
  {% if _pc_ch1 != blank %}
    {% assign _pc_choose = _pc_ch1 %}
  {% else %}
    {% assign _pc_choose = theme_data.grid_products_choose_options_label | default: add | default: 'Choose options' | strip %}
  {% endif %}
  {% assign _hp_title = section_title | strip %}
  {% assign _hp_show_viewall = false %}
  {% if category and category.slug and hide_view_all != true %}
    {% assign _hp_show_viewall = true %}
  {% endif %}
  {% assign _hp_viewall_text = theme_data.grid_products_view_all_label | strip %}
  {% if _hp_viewall_text == blank %}
    {% assign _hp_viewall_text = 'Shop All Products' %}
  {% endif %}

  <div class="ps-ab-pgrid-shell">
    {% if _hp_title != blank or _hp_show_viewall %}
    <div class="ps-ab-pgrid-header">
      {% if _hp_title != blank %}
        <h2 class="ps-ab-pgrid-header__title">{{ _hp_title }}</h2>
      {% endif %}
      {% if _hp_show_viewall %}
        <a href="/collections/{{ category.slug }}" class="ps-hpgrid-view-all-btn">
          <span class="ps-hpgrid-view-all-btn__text">{{ _hp_viewall_text }}</span>
        </a>
      {% endif %}
    </div>
    {% endif %}
    <div class="ab-pgrid-wrap">
      {% for product in products limit: 8 %}
        {% assign color_variation = product.variations | where: "type", "color" | first %}
        {% assign image_variation = product.variations | where: "type", "image" | first %}
        {% assign swatch_total = 0 %}
        {% if color_variation and color_variation.props %}
          {% assign swatch_total = color_variation.props.size %}
        {% elsif image_variation and image_variation.props %}
          {% assign swatch_total = image_variation.props.size %}
        {% endif %}

        {% assign is_on_sale = false %}
        {% assign discount = 0 %}
        {% if product.sale_price and product.price and product.sale_price < product.price %}
          {% assign is_on_sale = true %}
          {% assign discount = product.price | minus: product.sale_price | times: 100 | divided_by: product.price | floor %}
        {% endif %}

        <div>
          <div class="ps-product-card ps-store-card ps-u-h-full">
            <a
              href="/products/{{ product.slug }}"
              class="ps-store-card-stretch-link"
              aria-label="{{ product.name }}"
            ></a>
            <div class="ps-product-media">
              {% if is_on_sale %}
                <span class="ps-product-badge ps-sale-badge">-{{ discount }}%</span>
              {% endif %}

              <img
                class="ps-product-img-primary"
                src="{{ product.thumb }}"
                alt="{{ product.name }}"
                loading="lazy"
              />

              {% if product.images[0] %}
                <img
                  class="ps-product-img-hover"
                  src="{{ product.images[0] }}"
                  alt="{{ product.name }}"
                  loading="lazy"
                />
              {% endif %}

              <button
                class="ps-card-qview ps-product-search-btn-reset"
                type="button"
                aria-label="Quick view"
                title="Quick view"
                onclick="event.preventDefault();event.stopPropagation();this.dispatchEvent(new CustomEvent('quick-view',{bubbles:true,detail:{productId:'{{ product.id }}'}}));"
              >
                <img src="{{ _pc_search }}" alt="" class="ps-card-qview-img" width="20" height="20" loading="lazy" decoding="async" />
              </button>

              <button
                class="ps-card-choose ps-product-choose-btn"
                type="button"
                aria-label="{{ _pc_choose }}"
                onclick="event.preventDefault();event.stopPropagation();this.dispatchEvent(new CustomEvent('quick-add',{bubbles:true,detail:{productId:'{{ product.id }}'}}));"
              >
                {{ _pc_choose }}
              </button>

              <button
                class="ps-card-mcart ps-product-quick-add"
                type="button"
                aria-label="Add to cart"
                onclick="event.preventDefault();event.stopPropagation();this.dispatchEvent(new CustomEvent('quick-add',{bubbles:true,detail:{productId:'{{ product.id }}'}}));"
              >
                <img src="{{ theme_data.header_cart_icon | strip | default: 'https://files.easy-orders.net/1777884423251467919cart.svg' }}" alt="" class="ps-icon-image ps-card-mcart-icon" width="20" height="20" loading="lazy" decoding="async" />
              </button>
            </div>

            <div class="ps-product-info">
              {% if category and category.name %}
                <p class="ps-product-category ps-store-card__cat">{{ category.name }}</p>
              {% elsif product.type != blank %}
                <p class="ps-product-category ps-store-card__cat">{{ product.type }}</p>
              {% endif %}

              <span class="ps-product-name">
                {{ product.name }}
              </span>

              {% unless theme_data.product_card_show_swatches == false %}
              {% if swatch_total > 0 %}
              <div class="ps-pgrid-swatches">
                {% if color_variation and color_variation.props %}
                  {% for prop in color_variation.props limit: 6 %}
                    <a
                      href="/products/{{ product.slug }}"
                      class="ps-pgrid-swatch"
                      style="background: {{ prop.value }}"
                      title="{{ prop.name }}"
                    ></a>
                  {% endfor %}
                {% elsif image_variation and image_variation.props %}
                  {% for prop in image_variation.props limit: 6 %}
                    <a href="/products/{{ product.slug }}" class="ps-pgrid-swatch ps-pgrid-swatch-image" title="{{ prop.name }}">
                      <img src="{{ prop.value }}" alt="{{ prop.name }}" loading="lazy" />
                    </a>
                  {% endfor %}
                {% endif %}
                {% if swatch_total > 6 %}
                  <span class="ps-pgrid-swatch-more">+{{ swatch_total | minus: 6 }}</span>
                {% endif %}
              </div>
              {% endif %}
              {% endunless %}

              <div class="ps-product-price">
                {% if is_on_sale %}
                  <span class="ps-product-price-sale">{{ product.sale_price }} {{ currency }}</span>
                  <span class="ps-product-price-original">{{ product.price }} {{ currency }}</span>
                {% else %}
                  <span class="ps-product-price-current">{{ product.price }} {{ currency }}</span>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
