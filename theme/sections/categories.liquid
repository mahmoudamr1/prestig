{% if categories and categories.size > 0 %}
<div class="ab-categories-section">
  <header class="ab-categories-header">
    <p class="ab-categories-kicker">{{ theme_data.categories_header_subtitle | default: 'best seller collections' }}</p>
    <h2 class="ab-categories-title">{{ theme_data.categories_header_title | default: 'Shop by Category' }}</h2>
  </header>
  <div class="ab-categories">
    <div class="ab-categories-track">
      {% for category in categories %}
        <a
          href="/collections/{{ category.slug }}"
          class="ab-cat-card ab-reveal"
          style="animation-delay: {{ forloop.index0 | times: 40 }}ms"
        >
          <img src="{{ category.thumb }}" alt="{{ category.name }}" loading="lazy" />
          <span class="ab-cat-label">{{ category.name }}</span>
        </a>
      {% endfor %}
    </div>
  </div>
</div>
{% endif %}
