{% if categories and categories.size > 0 %}
{% assign _cat_kicker = theme_data.categories_header_subtitle | strip %}
{% assign _cat_heading = theme_data.categories_header_title | strip %}
{% assign _cat_desc = theme_data.categories_section_description | strip %}
{% assign _cat_items_word = theme_data.categories_items_label | strip | default: 'items' %}
<div
  class="category-section-wrapper ab-categories-section ps-sr-scope"
  data-ps-cat-showcase
>
  <div class="category-section-inner">
    <div class="category-info-col">
      {% if _cat_kicker != blank %}
        <p class="category-info-col__kicker">{{ _cat_kicker }}</p>
      {% endif %}
      {% if _cat_heading != blank %}
        <h2 class="category-info-col__title">{{ _cat_heading }}</h2>
      {% endif %}
      {% if _cat_desc != blank %}
        <p class="category-info-col__desc">{{ _cat_desc }}</p>
      {% endif %}
      <div class="category-info-col__nav">
        <button
          type="button"
          class="category-carousel-btn category-carousel-btn--prev"
          data-ps-cat-prev
          aria-label="{{ theme_data.categories_carousel_prev_label | default: 'Previous categories' | escape }}"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <polyline points="15 18 9 12 15 6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button
          type="button"
          class="category-carousel-btn category-carousel-btn--next"
          data-ps-cat-next
          aria-label="{{ theme_data.categories_carousel_next_label | default: 'Next categories' | escape }}"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <polyline points="9 18 15 12 9 6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>
    <div class="category-slider-col">
      <div
        class="category-carousel-track"
        data-ps-cat-carousel
        tabindex="0"
      >
        {% for category in categories %}
          <article class="category-card">
            <a class="category-card__link" href="/collections/{{ category.slug }}">
              <div class="category-card__media">
                <img
                  class="category-card__img"
                  src="{{ category.thumb }}"
                  alt="{{ category.name }}"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="category-card__info">
                <h3 class="category-card__name">{{ category.name }}</h3>
                {% assign _n = category.products_count | default: category.product_count | default: category.total_products %}
                {% if _n != blank %}
                  <p class="category-card__count">{{ _n }} {{ _cat_items_word }}</p>
                {% endif %}
                <span class="category-card__arrow" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H9M17 7V15"/>
                  </svg>
                </span>
              </div>
            </a>
          </article>
        {% endfor %}
      </div>
    </div>
  </div>
</div>
{% endif %}
