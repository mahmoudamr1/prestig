{% if categories and categories.size > 0 %}<div class="ab-categories-section ps-sr-scope"><div class="ab-categories"><div class="ab-categories-grid">{% for category in categories %}<a class="ab-cat-tile" href="/collections/{{ category.slug }}" data-anim="fadeInUp" data-seq="{{ forloop.index0 }}"><span class="ab-cat-tile__media"><img class="ab-cat-tile__img" src="{{ category.thumb }}" alt="" loading="lazy" /><span class="ab-cat-tile__dim"></span></span><span class="ab-cat-tile__content"><span class="ab-cat-tile__title">{{ category.name }}</span></span></a>{% endfor %}</div></div></div>{% endif %}
