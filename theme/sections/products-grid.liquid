{% liquid
  assign _sale_badge_label = theme_data.sale_badge_label | strip
  if _sale_badge_label == blank
    assign _sale_badge_label = sale | strip
  endif
  if _sale_badge_label == blank
    assign _sale_badge_label = save_label | strip
  endif
  if _sale_badge_label == blank
    assign _sale_badge_label = "Save"
  endif
%}
<section class="ps-pgrid-section ps-pgrid-section--catalog ps-sr-scope" data-ps-pgrid><div class="ps-pgrid-inner"><div class="ps-pgrid-main"><div class="ps-pgrid-grid">{% for product in products %}{% liquid
  assign color_variation = product.variations | where: "type", "color" | first
  assign image_variation = product.variations | where: "type", "image" | first
  assign swatch_total = 0
  if color_variation and color_variation.props
    assign swatch_total = color_variation.props.size
  elsif image_variation and image_variation.props
    assign swatch_total = image_variation.props.size
  endif
  assign has_variations = false
  if product.variations and product.variations.size > 0
    assign has_variations = true
  endif
  assign qty = product.quantity | plus: 0
  assign show_card_cta = false
  assign use_quick_view = false
  if has_variations
    assign show_card_cta = true
    assign use_quick_view = true
  elsif product.disable_orders_for_no_stock
    if qty >= 1
      assign show_card_cta = true
      assign use_quick_view = false
    endif
  else
    assign show_card_cta = true
    assign use_quick_view = false
  endif
  assign _card_imgs = product.thumb
  if product.images and product.images.size > 0
    for image in product.images limit: 12
      if image != blank and image != product.thumb
        assign _card_imgs = _card_imgs | append: '|' | append: image
      endif
    endfor
  endif
  if product.gallery and product.gallery.size > 0
    for item in product.gallery limit: 12
      assign _gimg = item.thumbnail
      if _gimg != blank and _gimg != product.thumb
        assign _card_imgs = _card_imgs | append: '|' | append: _gimg
      endif
    endfor
  endif
  assign _card_img_count = _card_imgs | split: '|' | size
  assign _card_hover_img = ""
  assign _card_img_list = _card_imgs | split: '|'
  if _card_img_list.size > 1 and _card_img_list[1] != blank and _card_img_list[1] != product.thumb
    assign _card_hover_img = _card_img_list[1]
  endif
  assign _card_cta = theme_data.product_card_cta_label | strip
  if _card_cta == blank
    assign _card_cta = add | default: 'Add'
  endif
  assign _card_cta_hover = theme_data.product_card_cta_label_hover | strip
  if _card_cta_hover == blank
    assign _card_cta_hover = _card_cta
  endif
  assign list_price = product.price | plus: 0
  assign deal_price = product.sale_price | plus: 0
%}<a href="/products/{{ product.slug }}" class="ps-pgrid-card" data-anim="fadeInUp" data-seq="{{ forloop.index0 }}"><div class="ps-pgrid-media{% if _card_img_count > 1 %} ps-card-media--carousel{% endif %}"{% if _card_img_count > 1 %} data-ps-card-images="{{ _card_imgs | escape }}" data-ps-card-has-hover="1" onmouseenter="var m=this;var raw=m.getAttribute('data-ps-card-images');if(!raw)return;var imgs=raw.split('|').map(function(s){return s.trim();}).filter(Boolean);var p=m.querySelector('.ps-plist-img-primary,.ps-pgrid-img-primary');var h=m.querySelector('.ps-plist-img-hover,.ps-pgrid-img-hover');if(!p||!h||imgs.length&lt;2)return;var i=imgs.indexOf(p.getAttribute('src'));if(i&lt;0)i=0;var ni=i+1;if(ni&lt;imgs.length){h.src=imgs[ni];h.setAttribute('src',imgs[ni]);h.removeAttribute('hidden');m.setAttribute('data-ps-card-has-hover','1');}else{h.setAttribute('hidden','');m.removeAttribute('data-ps-card-has-hover');}"{% endif %}>{% if deal_price > 0 and list_price > 0 and deal_price < list_price %}{% assign discount = list_price | minus: deal_price | times: 100 | divided_by: list_price | floor %}<span class="ps-pgrid-badge ps-sale-badge">{{ _sale_badge_label }} {{ discount }}%</span>{% endif %}{% if product.product_theme_data.custom_badge_title and product.product_theme_data.custom_badge_title != "" %}<span class="ps-pgrid-badge ps-product-custom-badge">{{ product.product_theme_data.custom_badge_title }}</span>{% endif %}<img class="ps-pgrid-img-primary ps-card-media__img" src="{{ product.thumb }}" alt="{{ product.name }}" loading="lazy" />{% if _card_hover_img != "" %}<img class="ps-pgrid-img-hover" src="{{ _card_hover_img }}" alt="" loading="lazy" aria-hidden="true" />{% endif %}{% if _card_img_count > 1 %}<div class="ps-card-media__nav" aria-hidden="false"><button type="button" class="ps-card-media__arrow ps-card-media__arrow--prev" aria-label="Previous image" onclick="event.preventDefault();event.stopPropagation();var m=this.closest('[data-ps-card-images]');var imgs=(m.getAttribute('data-ps-card-images')||'').split('|').map(function(s){return s.trim();}).filter(Boolean);if(imgs.length&lt;2)return;var p=m.querySelector('.ps-plist-img-primary,.ps-pgrid-img-primary');var h=m.querySelector('.ps-plist-img-hover,.ps-pgrid-img-hover');var i=imgs.indexOf(p.getAttribute('src'));if(i&lt;0)i=0;i=(i-1+imgs.length)%imgs.length;p.src=imgs[i];p.setAttribute('src',imgs[i]);if(h){var ni=i+1;if(ni&lt;imgs.length){h.src=imgs[ni];h.setAttribute('src',imgs[ni]);h.removeAttribute('hidden');m.setAttribute('data-ps-card-has-hover','1');}else{h.setAttribute('hidden','');m.removeAttribute('data-ps-card-has-hover');}}"><img src="https://files.easy-orders.net/1779188833025272262www.svg" alt="" width="42" height="18" decoding="async" aria-hidden="true" /></button><button type="button" class="ps-card-media__arrow ps-card-media__arrow--next" aria-label="Next image" onclick="event.preventDefault();event.stopPropagation();var m=this.closest('[data-ps-card-images]');var imgs=(m.getAttribute('data-ps-card-images')||'').split('|').map(function(s){return s.trim();}).filter(Boolean);if(imgs.length&lt;2)return;var p=m.querySelector('.ps-plist-img-primary,.ps-pgrid-img-primary');var h=m.querySelector('.ps-plist-img-hover,.ps-pgrid-img-hover');var i=imgs.indexOf(p.getAttribute('src'));if(i&lt;0)i=0;i=(i+1)%imgs.length;p.src=imgs[i];p.setAttribute('src',imgs[i]);if(h){var ni=i+1;if(ni&lt;imgs.length){h.src=imgs[ni];h.setAttribute('src',imgs[ni]);h.removeAttribute('hidden');m.setAttribute('data-ps-card-has-hover','1');}else{h.setAttribute('hidden','');m.removeAttribute('data-ps-card-has-hover');}}"><img src="https://files.easy-orders.net/1779188833025272262www.svg" alt="" width="42" height="18" decoding="async" aria-hidden="true" /></button></div>{% endif %}{% if show_card_cta %}{% if use_quick_view %}<button type="button" class="ps-pgrid-add ps-product-quick-add" aria-label="Quick view" onclick="event.preventDefault();event.stopPropagation();this.dispatchEvent(new CustomEvent('quick-view',{bubbles:true,detail:{productId:'{{ product.id }}'}}));"><span class="ps-product-quick-add__icon" aria-hidden="true"><img class="ps-product-plus-icon" src="https://files.easy-orders.net/1778659565003721866prestig-product-card-icon-quick-add-plus.svg" alt="" width="12" height="12" loading="lazy" /></span><span class="ps-product-quick-add__label" aria-hidden="true"><span class="ps-product-quick-add__text ps-product-quick-add__text--rest">{{ _card_cta }}</span><span class="ps-product-quick-add__text ps-product-quick-add__text--hover">{{ _card_cta_hover }}</span></span></button>{% else %}<button type="button" class="ps-pgrid-add ps-product-quick-add" aria-label="{{ _card_cta_hover }}" onclick="event.preventDefault();event.stopPropagation();this.dispatchEvent(new CustomEvent('quick-add',{bubbles:true,detail:{productId:'{{ product.id }}'}}));"><span class="ps-product-quick-add__icon" aria-hidden="true"><img class="ps-product-plus-icon" src="https://files.easy-orders.net/1778659565003721866prestig-product-card-icon-quick-add-plus.svg" alt="" width="12" height="12" loading="lazy" /></span><span class="ps-product-quick-add__label" aria-hidden="true"><span class="ps-product-quick-add__text ps-product-quick-add__text--rest">{{ _card_cta }}</span><span class="ps-product-quick-add__text ps-product-quick-add__text--hover">{{ _card_cta_hover }}</span></span></button>{% endif %}{% elsif product.disable_orders_for_no_stock and has_variations == false and qty < 1 %}<span class="ps-pgrid-stock-badge" role="status">{{ theme_data.out_of_stock_card_label | strip | default: "Out of stock" }}</span>{% endif %}</div><div class="ps-pgrid-info"><div class="ps-pgrid-desc"><span class="ps-pgrid-name">{{ product.name }}</span><div class="ps-pgrid-price-row">{% if deal_price > 0 and list_price > 0 and deal_price < list_price %}<span class="ps-pgrid-price-current">{{ deal_price }} {{ currency }}</span><span class="ps-pgrid-price-old">{{ list_price }} {{ currency }}</span>{% else %}<span class="ps-pgrid-price-current">{{ list_price }} {{ currency }}</span>{% endif %}</div></div>{% if swatch_total > 0 %}<div class="ps-pgrid-swatches">{% if color_variation and color_variation.props %}{% for prop in color_variation.props limit: 5 %}<span class="ps-pgrid-swatch" style="--ps-swatch-color: {{ prop.value }}" title="{{ prop.name }}"></span>{% endfor %}{% elsif image_variation and image_variation.props %}{% for prop in image_variation.props limit: 5 %}<span class="ps-pgrid-swatch ps-pgrid-swatch-image" title="{{ prop.name }}"><img src="{{ prop.value }}" alt="{{ prop.name }}" loading="lazy" /></span>{% endfor %}{% endif %}{% if swatch_total > 5 %}<span class="ps-pgrid-swatch-more" aria-hidden="true">+</span>{% endif %}</div>{% endif %}</div></a>{% endfor %}</div>{% if category and category.slug %}<div class="ps-pgrid-footer" data-anim="fadeInUp" data-seq="8"><a href="/collections/{{ category.slug }}" class="ps-pgrid-view-all gap-2"><span>{{ shop_now }}</span><img src="https://files.easy-orders.net/1773832247629050805.webp" alt="" class="ps-viewall-arrow" width="20" height="20" loading="lazy" /></a></div>{% endif %}</div></div></section>
