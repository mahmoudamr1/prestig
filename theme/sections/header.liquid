{% comment %}Contract: .ps-theme(data-ps-*); .ps-announce[data-ps-announce]; #eo-header.ps-header; .ps-theme-layout-spacer; aside#eo-mobile-menu; #eo-menu-btn,#header-cart-count,#header-lang-*; palette on :root. Google Fonts URL built in script.js from data-ps-gf-families + data-ps-gf-weights.{% endcomment %}
{% liquid
  assign _ps_anim_on = true
  if theme_data.enable_theme_animations == false
    assign _ps_anim_on = false
  endif
  assign _logo_h = theme_data.header_logo_height | default: 46 | plus: 0
  if _logo_h < 1
    assign _logo_h = 46
  endif
  assign ann_cfg = announcement_config
  if ann_cfg == nil or ann_cfg.text == nil or ann_cfg.text.size == 0
    if announcement_bar and announcement_bar.text
      assign ann_cfg = announcement_bar
    endif
  endif
  assign ann_count = 0
  if ann_cfg and ann_cfg.text
    assign ann_count = ann_cfg.text | size
  endif
  assign ann_type_key = 'simple'
  if ann_cfg and ann_cfg.type != blank
    assign ann_type_key = ann_cfg.type | strip | downcase
  endif
  if ann_type_key != 'marquee' and ann_type_key != 'slider'
    assign ann_type_key = 'simple'
  endif
  assign ps_nav_pages_label = theme_data.footer_customer_support | default: 'Pages' | strip
  if ps_nav_pages_label == blank
    assign ps_nav_pages_label = 'Pages'
  endif
  assign ps_nav_more_label = theme_data.header_more_menu_label | default: 'More' | strip
  if ps_nav_more_label == blank
    assign ps_nav_more_label = 'More'
  endif
  assign ps_show_pages_nav = false
  if pages.size > 0
    assign ps_show_pages_nav = true
  else
    for category in categories
      assign cat_check_href = category.url | default: ''
      if cat_check_href contains '/pages/'
        assign ps_show_pages_nav = true
        break
      endif
    endfor
  endif
  assign ps_bottom_nav_on = true
  if theme_data.enable_bottom_nav == false
    assign ps_bottom_nav_on = false
  endif
  assign ps_bn_icon_home = theme_data.bottom_nav_icon_home | default: 'https://files.easy-orders.net/1781437240727064579toyo-u-demo.svg' | strip
  assign ps_bn_icon_products = theme_data.bottom_nav_icon_products | default: 'https://files.easy-orders.net/1781437240706920851toyo-u-demo.svg' | strip
  assign ps_bn_icon_cart = theme_data.bottom_nav_icon_cart | default: 'https://files.easy-orders.net/1781437240699805060Layer_1.svg' | strip
  assign ps_bn_icon_search = theme_data.bottom_nav_icon_search | default: 'https://files.easy-orders.net/1781437240716272394toyo-u-demo.svg' | strip
  assign ps_bn_icon_account = theme_data.bottom_nav_icon_account | default: 'https://files.easy-orders.net/1779172066420412752anchored-popover-component-buttondialog-account-svg.svg' | strip
  assign ps_bn_link_products = theme_data.bottom_nav_link_products | default: '/collections' | strip
  if ps_bn_link_products == blank
    assign ps_bn_link_products = '/collections'
  endif
  assign ps_bn_label_home = theme_data.bottom_nav_home_label | default: store_name | default: 'Home' | strip
  assign ps_bn_label_products = theme_data.bottom_nav_products_label | default: 'Products' | strip
  assign ps_bn_label_cart = theme_data.bottom_nav_cart_label | default: 'Cart' | strip
  assign ps_bn_label_search = theme_data.bottom_nav_search_label | default: 'Search' | strip
  assign ps_bn_label_account = theme_data.bottom_nav_account_label | default: 'Account' | strip
  assign ps_scroll_top_on = true
  if theme_data.enable_scroll_top == false
    assign ps_scroll_top_on = false
  endif
  assign ps_scroll_top_offset = theme_data.scroll_top_offset | default: 400 | plus: 0
  if ps_scroll_top_offset < 1
    assign ps_scroll_top_offset = 400
  endif
  assign ps_scroll_top_label = theme_data.scroll_top_label | default: 'Scroll to top' | strip
%}
<div class="ps-theme" data-ps-pages-label="{{ ps_nav_pages_label | escape }}" data-ps-more-label="{{ ps_nav_more_label | escape }}" data-ps-animations="{% if _ps_anim_on %}1{% else %}0{% endif %}" data-ps-gf-families="{{ theme_data.font_google_families | default: 'Instrument Sans' | escape }}" data-ps-gf-weights="{{ theme_data.font_google_weights | default: '400;500;600;700' | escape }}" data-ps-ff-primary="{{ theme_data.font_family_primary | default: 'Instrument Sans' | strip | replace: '"', '' | replace: "'", '' | escape }}" data-ps-ff-ui="{{ theme_data.font_family_ui | default: 'Manrope' | strip | replace: '"', '' | replace: "'", '' | escape }}" data-ps-ff-alt="{{ theme_data.font_family_alt | default: 'Nunito' | strip | replace: '"', '' | replace: "'", '' | escape }}" data-ps-ff-display="{{ theme_data.font_family_display | default: 'Playfair Display' | strip | replace: '"', '' | replace: "'", '' | escape }}" data-ps-ff-arabic="{{ theme_data.font_family_arabic | default: 'Almarai' | strip | replace: '"', '' | replace: "'", '' | escape }}">
  {% if ann_count > 0 %}
    <div class="ps-announce" data-ps-announce data-ann-type="{{ ann_type_key }}" role="region" aria-label="Announcement">
      {% if ann_type_key == 'marquee' %}
        {% assign ps_marquee_segments = 10 %}
        <div class="ps-announce-inner ps-announce-marquee"><div class="ps-announce-marquee-track" style="--ps-announce-marquee-segments: {{ ps_marquee_segments }};">{% for seg in (1..ps_marquee_segments) %}{% for item in ann_cfg.text %}<span class="ps-announce-marquee-item"{% if seg > 1 %} aria-hidden="true"{% endif %}>{{- item -}}</span>{% endfor %}{% endfor %}</div></div>
      {% elsif ann_type_key == 'slider' %}
        <div class="ps-announce-inner ps-announce-slider">{% for item in ann_cfg.text %}<div class="ps-announce-slide{% if forloop.first %} ps-active{% endif %}">{{ item }}</div>{% endfor %}</div>
      {% else %}
        <div class="ps-announce-inner ps-announce-simple">{% for item in ann_cfg.text %}<span>{{ item }}</span>{% unless forloop.last %}<span class="ps-announce-sep">&mdash;</span>{% endunless %}{% endfor %}</div>
      {% endif %}
    </div>
  {% elsif announcement_text and announcement_text != "" %}
    <div class="ps-announce" data-ps-announce data-ann-type="simple" role="region" aria-label="Announcement"><div class="ps-announce-inner ps-announce-simple"><span>{{ announcement_text }}</span></div></div>
  {% endif %}
  <header id="eo-header" class="ps-header"><div class="ps-header-inner">
    <div class="ps-left-group" data-anim="fadeInRight" data-seq="1">
      <button id="eo-menu-btn" class="ps-menu-btn" type="button" aria-label="Open menu"><img src="https://files.easy-orders.net/1773672562651251535hamburger.svg" alt="" class="ps-menu-icon" /></button>
      <a href="/search" class="ps-icon-btn search-btn ps-header-search--mobile" aria-label="Search" data-eo="search-btn"><img src="https://files.easy-orders.net/1780902583526422392.webp" alt="" class="ps-icon-image" width="20" height="20" /></a>
      <nav class="ps-desktop-nav" aria-label="Main navigation">
        <div class="ps-desktop-nav-inner">
          {% for category in categories %}
            {% assign cat_href = category.url %}
            {% if cat_href == blank %}
              {% if category.slug != blank %}
                {% assign cat_href = "/collections/" | append: category.slug %}
              {% else %}
                {% assign cat_href = "#" %}
              {% endif %}
            {% endif %}
            {% assign cat_is_page_link = false %}
            {% if cat_href contains '/pages/' %}
              {% assign cat_is_page_link = true %}
            {% endif %}
            {% unless cat_is_page_link %}
              {% assign cat_children_n = category.children | size %}
              {% if cat_children_n > 0 %}
                <div class="ps-nav-dropdown ps-nav-top-item ps-nav-top-item--category">
                  <a href="{{ cat_href }}" class="ps-desktop-nav-link ps-nav-dropdown-trigger">{{ category.name }}</a>
                  <div class="ps-nav-dropdown-panel">
                    {% for child in category.children %}
                      {% assign child_href = child.url %}
                      {% if child_href == blank %}
                        {% if child.slug != blank %}
                          {% assign child_href = "/collections/" | append: child.slug %}
                        {% else %}
                          {% assign child_href = "#" %}
                        {% endif %}
                      {% endif %}
                      <a href="{{ child_href }}">{{ child.name }}</a>
                    {% endfor %}
                  </div>
                </div>
              {% else %}
                <a href="{{ cat_href }}" class="ps-desktop-nav-link ps-nav-top-item">{{ category.name }}</a>
              {% endif %}
            {% endunless %}
          {% endfor %}
          {% if ps_show_pages_nav %}
            <div class="ps-nav-dropdown ps-nav-dropdown--pages ps-nav-top-item ps-nav-top-item--pages">
              <button type="button" class="ps-desktop-nav-link ps-nav-dropdown-trigger ps-nav-pages-trigger" aria-haspopup="true" aria-expanded="false">{{ ps_nav_pages_label }}</button>
              <div class="ps-nav-dropdown-panel ps-nav-dropdown-panel--pages" role="menu">
                {% if pages.size > 0 %}
                  {% for page in pages %}
                    <a href="/pages/{{ page.slug }}" class="ps-pages-dropdown-link" role="menuitem">{{ page.title }}</a>
                  {% endfor %}
                {% else %}
                  {% for category in categories %}
                    {% assign cat_href = category.url %}
                    {% if cat_href == blank %}
                      {% if category.slug != blank %}
                        {% assign cat_href = "/collections/" | append: category.slug %}
                      {% else %}
                        {% assign cat_href = "#" %}
                      {% endif %}
                    {% endif %}
                    {% if cat_href contains '/pages/' %}
                      <a href="{{ cat_href }}" class="ps-pages-dropdown-link" role="menuitem">{{ category.name }}</a>
                    {% endif %}
                  {% endfor %}
                {% endif %}
              </div>
            </div>
          {% endif %}
          <div class="ps-nav-dropdown ps-nav-dropdown--more ps-nav-top-item ps-nav-top-item--more" hidden data-ps-nav-more>
            <button type="button" class="ps-desktop-nav-link ps-nav-dropdown-trigger ps-nav-dropdown-trigger--btn" aria-expanded="false" aria-haspopup="true" id="ps-header-more-trigger">{{ ps_nav_more_label }}</button>
            <div class="ps-nav-dropdown-panel ps-nav-dropdown-panel--more ps-nav-dropdown-panel--pages" role="menu" aria-labelledby="ps-header-more-trigger">
              <ul class="ps-pages-dropdown-list ps-more-dropdown-list" data-ps-nav-more-list role="none"></ul>
            </div>
          </div>
        </div>
      </nav>
    </div>
    <a href="/" class="ps-logo" style="--ps-logo-img-h: {{ _logo_h }}px;" aria-label="{{ store_name }}" data-anim="zoomIn" data-seq="0">{% if logo != blank %}<img src="{{ logo }}" alt="{{ store_name }}" />{% else %}<span>{{ store_name }}</span>{% endif %}</a>
    <div class="ps-right-group" data-anim="fadeInLeft" data-seq="2">
      <a href="/search" class="ps-icon-btn search-btn ps-header-search--desktop" aria-label="Search" data-eo="search-btn"><img src="https://files.easy-orders.net/1780902583526422392.webp" alt="" class="ps-icon-image" width="20" height="20" /></a>
      <button type="button" id="header-lang-btn" class="ps-icon-btn lang-btn" aria-label="Change language" onclick="this.dispatchEvent(new CustomEvent('lang-click',{bubbles:true}))"><svg class="ps-icon-image ps-lang-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10" /><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" /></svg></button>
      {% if is_register_active %}
      <button type="button" id="header-register" class="ps-icon-btn register-btn" aria-label="Register" onclick="this.dispatchEvent(new CustomEvent('register-click',{bubbles:true}))"><img src="https://files.easy-orders.net/1779172066420412752anchored-popover-component-buttondialog-account-svg.svg" alt="" class="ps-icon-image" width="22" height="22" /></button>
      {% endif %}
      <button type="button" class="ps-icon-btn cart-btn" aria-label="Cart" onclick="this.dispatchEvent(new CustomEvent('cart-click',{bubbles:true}))"><img src="https://files.easy-orders.net/1780902583539474286.webp" alt="" class="ps-icon-image" width="20" height="20" /><span id="header-cart-count" class="ps-cart-count" {% if cart_count == 0 %}hidden{% endif %} aria-hidden="true">{{ cart_count }}</span></button>
    </div>
  </div></header>
  <div class="ps-theme-layout-spacer" aria-hidden="true"></div>
  <div id="eo-mobile-overlay" class="ps-mobile-overlay"></div>
  <aside id="eo-mobile-menu" class="ps-mobile-menu" aria-label="Mobile menu">
    <div class="ps-mobile-top">
      <button id="eo-mobile-close" class="ps-mobile-close" type="button" aria-label="Close menu"><img src="https://files.easy-orders.net/1773672706842218072x.svg" alt="" class="ps-close-icon" /></button>
      <a href="/" class="ps-logo ps-mobile-logo" aria-label="{{ store_name }}">{% if logo != blank %}<img src="{{ logo }}" alt="{{ store_name }}" />{% else %}<span>{{ store_name }}</span>{% endif %}</a>
    </div>
    <nav class="ps-mobile-nav" aria-label="Mobile navigation">{% for category in categories %}{% assign cat_href = category.url %}{% if cat_href == blank %}{% if category.slug != blank %}{% assign cat_href = "/collections/" | append: category.slug %}{% else %}{% assign cat_href = "#" %}{% endif %}{% endif %}{% assign cat_is_page_link = false %}{% if cat_href contains '/pages/' %}{% assign cat_is_page_link = true %}{% endif %}{% unless cat_is_page_link %}{% assign cat_children_n = category.children | size %}{% if cat_children_n > 0 %}<div class="ps-mobile-accordion"><button class="ps-mobile-link ps-accordion-trigger" type="button"><span>{{ category.name }}</span><img src="https://files.easy-orders.net/1780902583529910062.webp" alt="" width="10" height="6" class="ps-arrow-icon" aria-hidden="true" /></button><div class="ps-accordion-panel"><a href="{{ cat_href }}" class="ps-mobile-sublink">All {{ category.name }}</a>{% for child in category.children %}{% assign child_href = child.url %}{% if child_href == blank %}{% if child.slug != blank %}{% assign child_href = "/collections/" | append: child.slug %}{% else %}{% assign child_href = "#" %}{% endif %}{% endif %}<a href="{{ child_href }}" class="ps-mobile-sublink">{{ child.name }}</a>{% endfor %}</div></div>{% else %}<a href="{{ cat_href }}" class="ps-mobile-link"><span>{{ category.name }}</span></a>{% endif %}{% endunless %}{% endfor %}{% if ps_show_pages_nav %}<div class="ps-mobile-accordion ps-mobile-accordion--pages"><button class="ps-mobile-link ps-accordion-trigger" type="button"><span>{{ ps_nav_pages_label }}</span><img src="https://files.easy-orders.net/1780902583529910062.webp" alt="" width="10" height="6" class="ps-arrow-icon" aria-hidden="true" /></button><div class="ps-accordion-panel">{% if pages.size > 0 %}{% for page in pages %}<a href="/pages/{{ page.slug }}" class="ps-mobile-sublink">{{ page.title }}</a>{% endfor %}{% else %}{% for category in categories %}{% assign cat_href = category.url %}{% if cat_href == blank %}{% if category.slug != blank %}{% assign cat_href = "/collections/" | append: category.slug %}{% else %}{% assign cat_href = "#" %}{% endif %}{% endif %}{% if cat_href contains '/pages/' %}<a href="{{ cat_href }}" class="ps-mobile-sublink">{{ category.name }}</a>{% endif %}{% endfor %}{% endif %}</div></div>{% endif %}
      {% if is_register_active %}
      <button type="button" id="header-register-mobile" class="ps-mobile-link register-btn" aria-label="Register" onclick="this.dispatchEvent(new CustomEvent('register-click',{bubbles:true}))"><span>Register</span><img src="https://files.easy-orders.net/1779172066420412752anchored-popover-component-buttondialog-account-svg.svg" alt="" class="ps-mobile-row-icon" width="22" height="22" aria-hidden="true" /></button>
      {% endif %}
      <a href="/search" class="ps-mobile-link ps-mobile-link--iconrow" data-eo="search-btn"><span>Search</span><img class="ps-mobile-row-icon" src="https://files.easy-orders.net/1780902583526422392.webp" alt="" width="20" height="20" aria-hidden="true" /></a>
      <a id="header-lang-mobile" href="#" class="ps-mobile-link ps-mobile-link--iconrow lang-btn" onclick="this.dispatchEvent(new CustomEvent('lang-click',{bubbles:true}));return false;"><span>Language</span><svg class="ps-mobile-row-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10" /><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" /></svg></a>
    </nav>
  </aside>
  {% if ps_bottom_nav_on %}
  <nav class="ps-bottom-nav" data-ps-bottom-nav aria-label="Mobile bottom navigation">
    <ul class="ps-bottom-nav__list">
      <li class="ps-bottom-nav__item">
        <a href="/" class="ps-bottom-nav__link ps-bottom-nav__link--home" aria-label="{{ ps_bn_label_home | escape }}">
          <svg class="ps-bottom-nav__icon ps-bottom-nav__icon--svg" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M4.5 10.25V19a1.75 1.75 0 0 0 1.75 1.75H9.5v-5.5a1.25 1.25 0 0 1 1.25-1.25h2.5a1.25 1.25 0 0 1 1.25 1.25V20.75h3.25A1.75 1.75 0 0 0 19.5 19v-8.75L12 4.75 4.5 10.25Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </li>
      <li class="ps-bottom-nav__item">
        <a href="{{ ps_bn_link_products }}" class="ps-bottom-nav__link" aria-label="{{ ps_bn_label_products | escape }}">
          <img src="{{ ps_bn_icon_products }}" alt="" class="ps-bottom-nav__icon" width="24" height="24" aria-hidden="true" />
        </a>
      </li>
      <li class="ps-bottom-nav__item">
        <button type="button" class="ps-bottom-nav__link ps-bottom-nav__link--cart cart-btn" aria-label="{{ ps_bn_label_cart | escape }}" onclick="this.dispatchEvent(new CustomEvent('cart-click',{bubbles:true}))">
          <img src="{{ ps_bn_icon_cart }}" alt="" class="ps-bottom-nav__icon" width="24" height="24" aria-hidden="true" />
          <span id="ps-bottom-nav-cart-count" class="ps-bottom-nav__cart-count" aria-hidden="true">({{ cart_count }})</span>
        </button>
      </li>
      <li class="ps-bottom-nav__item">
        <a href="/search" class="ps-bottom-nav__link search-btn" data-eo="search-btn" aria-label="{{ ps_bn_label_search | escape }}">
          <img src="{{ ps_bn_icon_search }}" alt="" class="ps-bottom-nav__icon" width="24" height="24" aria-hidden="true" />
        </a>
      </li>
      {% if is_register_active %}
      <li class="ps-bottom-nav__item">
        <button type="button" class="ps-bottom-nav__link register-btn" aria-label="{{ ps_bn_label_account | escape }}" onclick="this.dispatchEvent(new CustomEvent('register-click',{bubbles:true}))">
          <img src="{{ ps_bn_icon_account }}" alt="" class="ps-bottom-nav__icon" width="24" height="24" aria-hidden="true" />
        </button>
      </li>
      {% endif %}
    </ul>
  </nav>
  {% endif %}
  {% if ps_scroll_top_on %}
  <div class="ps-scroll-top" data-ps-scroll-top data-ps-scroll-offset="{{ ps_scroll_top_offset }}">
    <button type="button" class="ps-scroll-top__btn" aria-label="{{ ps_scroll_top_label | escape }}">
      <svg class="ps-scroll-top__icon" width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M6.99825 0L5.76481 1.23375L10.6461 6.125H0V7.875H10.6461L5.76481 12.7663L6.99825 14L13.9965 7L6.99825 0Z" fill="currentColor" />
      </svg>
    </button>
  </div>
  {% endif %}
</div>
