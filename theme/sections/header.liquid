{% comment %} Dynamic Google Fonts + --ps-ff-* from theme_data — see schema (font_google_families / font_google_weights / font_family_*). {% endcomment %}
{% assign _fgw = theme_data.font_google_weights | default: '400;500;600;700' | strip %}
{% assign _fgs = theme_data.font_google_families | default: 'DM Sans, Almarai, Manrope, Montserrat, Nunito, Playfair Display, Instrument Sans' | strip %}
{% assign _fam_parts = _fgs | split: ',' %}
{% assign _q = '' %}
{% for _seg in _fam_parts %}
  {% assign _one = _seg | strip | replace: '"', '' | replace: "'", '' %}
  {% if _one != blank %}
    {% assign _enc = _one | replace: ' ', '+' %}
    {% assign _piece = 'family=' | append: _enc | append: ':wght@' | append: _fgw %}
    {% if _q == '' %}
      {% assign _q = _piece %}
    {% else %}
      {% assign _q = _q | append: '&' | append: _piece %}
    {% endif %}
  {% endif %}
{% endfor %}
{% if _q == '' %}
  {% assign _q = 'family=DM+Sans:wght@' | append: _fgw %}
{% endif %}
{% assign prestig_google_font_url = 'https://fonts.googleapis.com/css2?' | append: _q | append: '&display=swap' %}

{% assign _pf = theme_data.font_family_primary | strip | replace: '"', '' | replace: "'", '' %}
{% assign _fu = theme_data.font_family_ui | strip | replace: '"', '' | replace: "'", '' %}
{% assign _fa = theme_data.font_family_alt | strip | replace: '"', '' | replace: "'", '' %}
{% assign _fd = theme_data.font_family_display | strip | replace: '"', '' | replace: "'", '' %}
{% assign _fb = theme_data.font_family_arabic | strip | replace: '"', '' | replace: "'", '' %}
{% assign _fan = theme_data.font_family_announce | strip | replace: '"', '' | replace: "'", '' %}
{% if _pf == blank %}
  {% assign _pf = 'DM Sans' %}
{% endif %}
{% if _fu == blank %}
  {% assign _fu = 'Manrope' %}
{% endif %}
{% if _fa == blank %}
  {% assign _fa = 'Nunito' %}
{% endif %}
{% if _fd == blank %}
  {% assign _fd = 'Playfair Display' %}
{% endif %}
{% if _fb == blank %}
  {% assign _fb = 'Almarai' %}
{% endif %}
{% if _fan == blank %}
  {% assign _fan = 'DM Sans' %}
{% endif %}

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="stylesheet" href="{{ prestig_google_font_url }}" />
<style id="prestige-theme-font-vars">
  :root {
    --ps-ff-primary: "{{ _pf }}";
    --ps-ff-ui: "{{ _fu }}";
    --ps-ff-alt: "{{ _fa }}";
    --ps-ff-display: "{{ _fd }}";
    --ps-ff-arabic: "{{ _fb }}";
    --ps-ff-announce: "{{ _fan }}", var(--ps-ff-ui), system-ui, sans-serif;
  }
  html[lang="ar"] .ps-theme,
  .ps-theme[lang="ar"] {
    font-family: var(--ps-ff-arabic), var(--ps-ff-primary), sans-serif;
  }
</style>
<div class="ps-theme ps-theme-root">
  {% comment %}
    Platform sends `announcement_config`; some previews / config stubs use `announcement_bar`.
  {% endcomment %}
  {% assign ann_cfg = announcement_config %}
  {% if ann_cfg == nil or ann_cfg.text == nil or ann_cfg.text.size == 0 %}
    {% if announcement_bar and announcement_bar.text %}
      {% assign ann_cfg = announcement_bar %}
    {% endif %}
  {% endif %}

  {% assign ann_count = 0 %}
  {% if ann_cfg and ann_cfg.text %}
    {% assign ann_count = ann_cfg.text | size %}
  {% endif %}

  {% assign _ann_shell_class = "ps-announce ps-announce--fixed-shell" %}
  {% capture _ann_palette_css -%}
{%- if palette -%}
{%- assign panb = palette.ann_bg -%}
{%- assign pant = palette.ann_text -%}
{%- if panb != blank -%}--ann-bg: {{ panb }};{%- endif -%}
{%- if pant != blank -%}--ann-text: {{ pant }};{%- endif -%}
{%- endif -%}
{%- endcapture %}
  {% assign _ann_palette_trim = _ann_palette_css | strip %}

  {% if ann_count > 0 %}
    <div
      class="{{ _ann_shell_class }}"
      {% if _ann_palette_trim != blank %}style="{{ _ann_palette_trim }}"{% endif %}
      data-ps-announce
      data-ann-type="{{ ann_cfg.type }}"
      role="region"
      aria-label="Announcement"
    >
      {% if ann_cfg.type == "marquee" %}
        <div class="ps-announce-inner ps-announce-marquee ps-ann-flex-grow">
          <div class="ps-announce-marquee-track ps-ann-marquee-track">
            {% for item in ann_cfg.text %}
              <span class="ps-announce-marquee-item ps-ann-no-shrink">{{ item }}</span>
            {% endfor %}
            {% for item in ann_cfg.text %}
              <span class="ps-announce-marquee-item ps-ann-no-shrink" aria-hidden="true">{{ item }}</span>
            {% endfor %}
          </div>
        </div>
      {% elsif ann_cfg.type == "slider" %}
        <div class="ps-announce-inner ps-announce-slider ps-ann-text-reset ps-ann-rel ps-ann-flex-grow ps-ann-min-w-0">
          {% for item in ann_cfg.text %}
            <div class="ps-announce-slide ps-ann-slide-item{% if forloop.first %} ps-active{% endif %}">{{ item }}</div>
          {% endfor %}
        </div>
      {% else %}
        <div class="ps-announce-inner ps-announce-simple ps-ann-text-reset ps-ann-simple-row">
          {% for item in ann_cfg.text %}
            <span class="ps-ann-inline-block">{{ item }}</span>
            {% unless forloop.last %}<span class="ps-announce-sep ps-ann-sep">&mdash;</span>{% endunless %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  {% elsif announcement_text and announcement_text != "" %}
    <div
      class="{{ _ann_shell_class }}"
      {% if _ann_palette_trim != blank %}style="{{ _ann_palette_trim }}"{% endif %}
      data-ps-announce
      role="region"
      aria-label="Announcement"
    >
      <div class="ps-announce-inner ps-ann-flex-grow ps-ann-min-w-0 ps-ann-fallback-inner">
        {{ announcement_text }}
      </div>
    </div>
  {% endif %}

  {% assign ps_header_needs_pages_dd = false %}
  {% if pages.size > 0 %}
    {% assign ps_header_needs_pages_dd = true %}
  {% endif %}
  {% for category in categories %}
    {% assign _ps_cat_href = category.url %}
    {% if _ps_cat_href == blank %}
      {% if category.slug != blank %}
        {% assign _ps_cat_href = "/collections/" | append: category.slug %}
      {% else %}
        {% assign _ps_cat_href = "" %}
      {% endif %}
    {% endif %}
    {% if _ps_cat_href contains "/pages/" %}
      {% assign ps_header_needs_pages_dd = true %}
    {% endif %}
    {% for page in pages %}
      {% if page.slug == category.slug %}
        {% assign ps_header_needs_pages_dd = true %}
      {% endif %}
    {% endfor %}
  {% endfor %}

  <header
    id="eo-header"
    class="ps-header"
    {% if palette %}
      {% assign phdb = palette.hd_bg %}
      {% assign phdt = palette.hd_text %}
      {% if phdb != blank or phdt != blank %}
        style="{% if phdb != blank %}--hd-bg: {{ phdb }};{% endif %}{% if phdt != blank %}--hd-text: {{ phdt }};{% endif %}"
      {% endif %}
    {% endif %}
  >
    <div class="ps-header-inner">
        <div class="ps-header-zone ps-header-zone--menu">
          <button id="eo-menu-btn" class="ps-menu-btn" type="button" aria-label="Open menu">
            <img src="{{ theme_data.header_hamburger_icon | strip | default: 'https://files.easy-orders.net/1777884423237977559hamburger%20icon%20for%20phones%20header%20.svg' }}" alt="" class="ps-menu-icon" />
          </button>
        </div>
        <a href="/" class="ps-logo ps-header-logo-main" aria-label="{{ store_name }}">
          {% if logo != blank %}
            <img src="{{ logo }}" alt="{{ store_name }}" />
          {% else %}
            <span class="ps-logo-text">{{ store_name }}</span>
          {% endif %}
        </a>

        <nav class="ps-desktop-nav" aria-label="Main navigation">
          <div class="ps-desktop-nav-inner">
            <a href="/" class="ps-desktop-nav-link">Home</a>
            {% for category in categories %}
              {% assign cat_href = category.url %}
              {% if cat_href == blank %}
                {% if category.slug != blank %}
                  {% assign cat_href = "/collections/" | append: category.slug %}
                {% else %}
                  {% assign cat_href = "#" %}
                {% endif %}
              {% endif %}
              {% unless cat_href contains "/pages/" %}
                {% assign ps_cat_dup_page = false %}
                {% for page in pages %}
                  {% if page.slug == category.slug %}
                    {% assign ps_cat_dup_page = true %}
                  {% endif %}
                {% endfor %}
                {% unless ps_cat_dup_page %}
                  {% assign cat_children_n = category.children | size %}
                  {% if cat_children_n > 0 %}
                    <div class="ps-nav-dropdown">
                      <a href="{{ cat_href }}" class="ps-desktop-nav-link ps-nav-dropdown-trigger ps-nav-dropdown-trigger--link">
                        <span>{{ category.name }}</span>
                        <img src="{{ theme_data.header_nav_chevron_icon | strip | default: 'https://files.easy-orders.net/1777884423218668962arrow%20for%20categories.svg' }}" alt="" class="ps-nav-chevron" width="12" height="12" />
                      </a>
                      <div class="ps-nav-dropdown-panel">
                        {% for child in category.children %}
                          {% assign child_href = child.url %}
                          {% if child_href == blank %}
                            {% if child.slug != blank %}
                              {% assign child_href = "/collections/" | append: child.slug %}
                            {% else %}
                              {% assign child_href = "#" %}
                            {% endif %}
                          {% endif %}
                          <a href="{{ child_href }}">{{ child.name }}</a>
                        {% endfor %}
                      </div>
                    </div>
                  {% else %}
                    <a href="{{ cat_href }}" class="ps-desktop-nav-link">{{ category.name }}</a>
                  {% endif %}
                {% endunless %}
              {% endunless %}
            {% endfor %}
            {% if ps_header_needs_pages_dd %}
              <div class="ps-nav-dropdown ps-nav-dropdown--pages">
                <button
                  type="button"
                  class="ps-desktop-nav-link ps-nav-dropdown-trigger ps-nav-dropdown-trigger--btn"
                  aria-expanded="false"
                  aria-haspopup="true"
                  id="ps-header-pages-trigger"
                >
                  <span>{{ theme_data.header_pages_menu_label | strip | default: 'Pages' }}</span>
                  <img
                    src="{{ theme_data.header_pages_chevron_icon | strip | default: 'https://files.easy-orders.net/1777885936858131198arrow%20down%20.svg' }}"
                    alt=""
                    class="ps-nav-chevron ps-nav-chevron--pages"
                    width="12"
                    height="12"
                  />
                </button>
                <div
                  class="ps-nav-dropdown-panel ps-nav-dropdown-panel--pages"
                  role="menu"
                  aria-labelledby="ps-header-pages-trigger"
                >
                  <ul class="ps-pages-dropdown-list" role="none">
                    {% for page in pages %}
                      <li role="none">
                        <a
                          href="/pages/{{ page.slug }}"
                          class="ps-pages-dropdown-link"
                          role="menuitem"
                        >{{ page.title }}</a>
                      </li>
                    {% endfor %}
                    {% for category in categories %}
                      {% assign cat_href = category.url %}
                      {% if cat_href == blank %}
                        {% if category.slug != blank %}
                          {% assign cat_href = "/collections/" | append: category.slug %}
                        {% else %}
                          {% assign cat_href = "#" %}
                        {% endif %}
                      {% endif %}
                      {% if cat_href contains "/pages/" %}
                        {% assign ps_cat_dd_dup = false %}
                        {% for page in pages %}
                          {% if page.slug == category.slug %}
                            {% assign ps_cat_dd_dup = true %}
                          {% endif %}
                        {% endfor %}
                        {% unless ps_cat_dd_dup %}
                          <li role="none">
                            <a
                              href="{{ cat_href }}"
                              class="ps-pages-dropdown-link"
                              role="menuitem"
                            >{{ category.name }}</a>
                          </li>
                        {% endunless %}
                      {% endif %}
                    {% endfor %}
                  </ul>
                </div>
              </div>
            {% endif %}
          </div>
        </nav>

        <div class="ps-header-tools">
          <a href="/search" class="ps-icon-btn search-btn" aria-label="Search" data-eo="search-btn">
            <img src="{{ theme_data.header_search_icon | strip | default: 'https://files.easy-orders.net/1777884423228231659search%20icon%20for%20prduct%20cards%20.svg' }}" alt="" class="ps-icon-image" width="22" height="22" />
          </a>
          {% if is_register_active %}
            <a
              href="/register"
              class="ps-icon-btn register-btn"
              aria-label="Account"
              onclick="this.dispatchEvent(new CustomEvent('register-click',{bubbles:true})); return false;"
            >
              <svg class="ps-icon-image ps-account-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 1 1-8 0 4 4 0 0 1 8 0ZM4 21a8 8 0 1 1 16 0"/>
              </svg>
            </a>
          {% endif %}
          <button
            type="button"
            id="header-lang-btn"
            class="lang-btn ps-u-visually-hidden"
            onclick="this.dispatchEvent(new CustomEvent('lang-click',{bubbles:true,detail:{anchor:this}}))"
          >Language</button>
          <button
            type="button"
            class="ps-icon-btn cart-btn"
            aria-label="Cart"
            onclick="this.dispatchEvent(new CustomEvent('cart-click',{bubbles:true}))"
          >
            <img src="{{ theme_data.header_cart_icon | strip | default: 'https://files.easy-orders.net/1777884423251467919cart.svg' }}" alt="" class="ps-icon-image" width="22" height="22" />
            <span
              id="header-cart-count"
              class="ps-cart-count"
              {% if cart_count == 0 %}hidden{% endif %}
              aria-hidden="true"
            >{{ cart_count }}</span>
          </button>
        </div>
    </div>
  </header>

  <div class="ps-theme-layout-spacer" style="pointer-events: none" aria-hidden="true"></div>

  <div id="eo-mobile-overlay" class="ps-mobile-overlay"></div>
  <aside id="eo-mobile-menu" class="ps-mobile-menu" aria-label="Mobile menu">
    <div class="ps-mobile-menu__inner">
      <div class="ps-mobile-top">
        <a href="/" class="ps-logo ps-mobile-logo" aria-label="{{ store_name }}">
          {% if logo != blank %}
            <img src="{{ logo }}" alt="{{ store_name }}" />
          {% else %}
            <span class="ps-logo-text">{{ store_name }}</span>
          {% endif %}
        </a>
        <button id="eo-mobile-close" class="ps-mobile-close" type="button" aria-label="Close menu">
          <svg class="ps-close-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
            <path d="M18.75 5.13496L5.25 18.8544" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M18.75 18.8544L5.25 5.13496" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

      <nav class="ps-mobile-nav" aria-label="Mobile navigation">
        <div class="ps-mobile-nav-scroll">
      <a href="/" class="ps-mobile-link">
        <span>Home</span>
      </a>
      {% for category in categories %}
        {% assign cat_href = category.url %}
        {% if cat_href == blank %}
          {% if category.slug != blank %}
            {% assign cat_href = "/collections/" | append: category.slug %}
          {% else %}
            {% assign cat_href = "#" %}
          {% endif %}
        {% endif %}
        {% unless cat_href contains "/pages/" %}
          {% assign ps_cat_dup_page = false %}
          {% for page in pages %}
            {% if page.slug == category.slug %}
              {% assign ps_cat_dup_page = true %}
            {% endif %}
          {% endfor %}
          {% unless ps_cat_dup_page %}
            {% assign cat_children_n = category.children | size %}
            {% if cat_children_n > 0 %}
              <div class="ps-mobile-accordion">
                <button class="ps-mobile-link ps-accordion-trigger" type="button">
                  <span>{{ category.name }}</span>
                  <svg class="ps-mobile-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                    <path d="M7.5 3.74121L13.75 9.99121L7.5 16.2412" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <div class="ps-accordion-panel">
                  <a href="{{ cat_href }}" class="ps-mobile-sublink">All {{ category.name }}</a>
                  {% for child in category.children %}
                    {% assign child_href = child.url %}
                    {% if child_href == blank %}
                      {% if child.slug != blank %}
                        {% assign child_href = "/collections/" | append: child.slug %}
                      {% else %}
                        {% assign child_href = "#" %}
                      {% endif %}
                    {% endif %}
                    <a href="{{ child_href }}" class="ps-mobile-sublink">{{ child.name }}</a>
                  {% endfor %}
                </div>
              </div>
            {% else %}
              <a href="{{ cat_href }}" class="ps-mobile-link">
                <span>{{ category.name }}</span>
              </a>
            {% endif %}
          {% endunless %}
        {% endunless %}
      {% endfor %}

      {% if ps_header_needs_pages_dd %}
        <div class="ps-mobile-accordion ps-mobile-accordion--pages">
          <button class="ps-mobile-link ps-mobile-link--pages-row ps-accordion-trigger" type="button">
            <span class="ps-mobile-link__label">{{ theme_data.header_pages_menu_label | strip | default: 'Pages' }}</span>
            <svg class="ps-mobile-pages-arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
              <path d="M7.5 3.74121L13.75 9.99121L7.5 16.2412" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="ps-accordion-panel">
            {% for page in pages %}
              <a href="/pages/{{ page.slug }}" class="ps-mobile-sublink">{{ page.title }}</a>
            {% endfor %}
            {% for category in categories %}
              {% assign cat_href = category.url %}
              {% if cat_href == blank %}
                {% if category.slug != blank %}
                  {% assign cat_href = "/collections/" | append: category.slug %}
                {% else %}
                  {% assign cat_href = "#" %}
                {% endif %}
              {% endif %}
              {% if cat_href contains "/pages/" %}
                {% assign ps_cat_dd_dup = false %}
                {% for page in pages %}
                  {% if page.slug == category.slug %}
                    {% assign ps_cat_dd_dup = true %}
                  {% endif %}
                {% endfor %}
                {% unless ps_cat_dd_dup %}
                  <a href="{{ cat_href }}" class="ps-mobile-sublink">{{ category.name }}</a>
                {% endunless %}
              {% endif %}
            {% endfor %}
          </div>
        </div>
      {% endif %}

      <a href="/search" class="ps-mobile-link ps-mobile-link--iconrow" data-eo="search-btn">
        <span>Search</span>
        <img
          src="{{ theme_data.header_search_icon | strip | default: 'https://files.easy-orders.net/1777884423228231659search%20icon%20for%20prduct%20cards%20.svg' }}"
          alt=""
          class="ps-mobile-row-icon"
          width="20"
          height="20"
          loading="lazy"
          decoding="async"
        />
      </a>

      <div id="header-lang-mobile" class="ps-mobile-accordion ps-mobile-accordion--lang">
        <button
          class="ps-mobile-link ps-mobile-link--pages-row ps-accordion-trigger"
          type="button"
        >
          <span class="ps-mobile-link__label">{{ theme_data.header_language_menu_label | strip | default: 'Language' }}</span>
          <svg class="ps-mobile-pages-arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
            <path d="M7.5 3.74121L13.75 9.99121L7.5 16.2412" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="ps-accordion-panel">
          {% assign _ps_lang_opts = theme_data.header_language_options %}
          {% if _ps_lang_opts and _ps_lang_opts.size > 0 %}
            {% for opt in _ps_lang_opts %}
              {% assign _lo = opt.label | strip %}
              {% assign _lu = opt.url | strip %}
              {% if _lo != blank and _lu != blank %}
                <a href="{{ _lu }}" class="ps-mobile-sublink">{{ _lo }}</a>
              {% endif %}
            {% endfor %}
          {% else %}
            <button
              type="button"
              class="ps-mobile-sublink ps-mobile-sublink--btn lang-btn"
              onclick="this.dispatchEvent(new CustomEvent('lang-click',{bubbles:true,detail:{anchor:this}}))"
            >
              {{ theme_data.header_language_fallback_label | strip | default: 'Change language' }}
            </button>
          {% endif %}
        </div>
      </div>
        </div>

      {% if is_register_active %}
        <div class="ps-mobile-menu__footer">
          <a
            href="/register"
            class="ps-mobile-drawer-login register-btn"
            onclick="this.dispatchEvent(new CustomEvent('register-click',{bubbles:true})); return false;"
          >{{ theme_data.header_drawer_login_label | default: 'Log in' }}</a>
        </div>
      {% endif %}
      </nav>
    </div>
  </aside>
</div>
