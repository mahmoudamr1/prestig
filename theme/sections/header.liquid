{% liquid
  assign _logo_h = theme_data.header_logo_height | default: 46 | plus: 0
  if _logo_h < 1
    assign _logo_h = 46
  endif
  assign _store_card_bg = theme_data.store_product_card_background | strip
  if _store_card_bg == blank
    assign _store_card_bg = '#f7f7f7'
  endif
  assign _sale_badge_bg = theme_data.product_card_sale_badge_bg | strip
  if _sale_badge_bg == blank
    assign _sale_badge_bg = '#e32c2b'
  endif
  assign _sale_badge_text = theme_data.product_card_sale_badge_text | strip
  if _sale_badge_text == blank
    assign _sale_badge_text = '#ffffff'
  endif
  assign _custom_badge_bg = theme_data.product_card_custom_badge_bg | strip
  if _custom_badge_bg == blank
    assign _custom_badge_bg = '#4fa355'
  endif
  assign _custom_badge_text = theme_data.product_card_custom_badge_text | strip
  if _custom_badge_text == blank
    assign _custom_badge_text = '#ffffff'
  endif
  assign ann_cfg = announcement_config
  if ann_cfg == nil or ann_cfg.text == nil or ann_cfg.text.size == 0
    if announcement_bar and announcement_bar.text
      assign ann_cfg = announcement_bar
    endif
  endif
  assign ann_count = 0
  if ann_cfg and ann_cfg.text
    assign ann_count = ann_cfg.text | size
  endif
  assign ann_type_key = 'simple'
  if ann_cfg and ann_cfg.type != blank
    assign ann_type_key = ann_cfg.type | strip | downcase
  endif
  if ann_type_key != 'marquee' and ann_type_key != 'slider'
    assign ann_type_key = 'simple'
  endif
  assign ps_header_needs_pages_dd = false
  if pages.size > 0
    assign ps_header_needs_pages_dd = true
  endif
  for category in categories
    assign _ps_cat_href = category.url
    if _ps_cat_href == blank
      if category.slug != blank
        assign _ps_cat_href = '/collections/' | append: category.slug
      else
        assign _ps_cat_href = ''
      endif
    endif
    if _ps_cat_href contains '/pages/'
      assign ps_header_needs_pages_dd = true
    endif
    for page in pages
      if page.slug == category.slug
        assign ps_header_needs_pages_dd = true
      endif
    endfor
  endfor
%}
<script type="application/json" id="prestige-theme-runtime-config">{"animations":"{% if theme_data.enable_theme_animations == false %}0{% else %}1{% endif %}","googleFontFamilies":"{{ theme_data.font_google_families | default: 'DM Sans, Almarai, Manrope, Montserrat, Nunito, Playfair Display, Instrument Sans' | strip | replace: '"', '' | replace: "'", '' | escape }}","googleFontWeights":"{{ theme_data.font_google_weights | default: '400;500;600;700' | strip | replace: '"', '' | replace: "'", '' | escape }}","fontFamilyPrimary":"{{ theme_data.font_family_primary | default: 'DM Sans' | strip | replace: '"', '' | replace: "'", '' | escape }}","fontFamilyUi":"{{ theme_data.font_family_ui | default: 'Manrope' | strip | replace: '"', '' | replace: "'", '' | escape }}","fontFamilyAlt":"{{ theme_data.font_family_alt | default: 'Nunito' | strip | replace: '"', '' | replace: "'", '' | escape }}","fontFamilyDisplay":"{{ theme_data.font_family_display | default: 'Playfair Display' | strip | replace: '"', '' | replace: "'", '' | escape }}","fontFamilyArabic":"{{ theme_data.font_family_arabic | default: 'Almarai' | strip | replace: '"', '' | replace: "'", '' | escape }}","fontFamilyAnnounce":"{{ theme_data.font_family_announce | default: 'DM Sans' | strip | replace: '"', '' | replace: "'", '' | escape }}","storeProductCardBackground":"{{ _store_card_bg | escape }}","productCardSaleBadgeBg":"{{ _sale_badge_bg | escape }}","productCardSaleBadgeText":"{{ _sale_badge_text | escape }}","productCardCustomBadgeBg":"{{ _custom_badge_bg | escape }}","productCardCustomBadgeText":"{{ _custom_badge_text | escape }}"}</script>
<div class="ps-theme ps-theme-root" style="--ps-store-sale-badge-bg: {{ _sale_badge_bg }}; --ps-store-sale-badge-text: {{ _sale_badge_text }}; --ps-store-custom-badge-bg: {{ _custom_badge_bg }}; --ps-store-custom-badge-text: {{ _custom_badge_text }};">
  {% if ann_count > 0 %}
    <div class="ps-announce" data-ps-announce data-ann-type="{{ ann_type_key }}" role="region" aria-label="Announcement" data-anim="fadeInDown" data-seq="0">
      {% if ann_type_key == 'marquee' %}
        {% assign ps_marquee_segments = 10 %}
        <div class="ps-announce-inner ps-announce-marquee"><div class="ps-announce-marquee-track" style="--ps-announce-marquee-segments: {{ ps_marquee_segments }};">{% for seg in (1..ps_marquee_segments) %}{% for item in ann_cfg.text %}<span class="ps-announce-marquee-item"{% if seg > 1 %} aria-hidden="true"{% endif %}>{{- item -}}</span>{% endfor %}{% endfor %}</div></div>
      {% elsif ann_type_key == 'slider' %}
        <div class="ps-announce-inner ps-announce-slider">{% for item in ann_cfg.text %}<div class="ps-announce-slide{% if forloop.first %} ps-active{% endif %}">{{ item }}</div>{% endfor %}</div>
      {% else %}
        <div class="ps-announce-inner ps-announce-simple">{% for item in ann_cfg.text %}<span>{{ item }}</span>{% unless forloop.last %}<span class="ps-announce-sep">&mdash;</span>{% endunless %}{% endfor %}</div>
      {% endif %}
    </div>
  {% elsif announcement_text and announcement_text != "" %}
    <div class="ps-announce" data-ps-announce data-ann-type="simple" role="region" aria-label="Announcement" data-anim="fadeInDown" data-seq="0"><div class="ps-announce-inner ps-announce-simple"><span>{{ announcement_text }}</span></div></div>
  {% endif %}
  <header id="eo-header" class="ps-header">
    <div class="ps-header-inner">
      <div class="ps-header-zone ps-header-zone--menu" data-anim="fadeInRight" data-seq="1"><button id="eo-menu-btn" class="ps-menu-btn" type="button" aria-label="Open menu"><img src="{{ theme_data.header_hamburger_icon | strip | default: 'https://files.easy-orders.net/1777884423237977559hamburger%20icon%20for%20phones%20header%20.svg' }}" alt="" class="ps-menu-icon" /></button></div>
      <a href="/" class="ps-logo ps-header-logo-main" style="--ps-logo-img-h: {{ _logo_h }}px;" aria-label="{{ store_name }}" data-anim="zoomIn" data-seq="0">{% if logo != blank %}<img src="{{ logo }}" alt="{{ store_name }}" />{% else %}<span class="ps-logo-text">{{ store_name }}</span>{% endif %}</a>
      <nav class="ps-desktop-nav" aria-label="Main navigation" data-anim="fadeInDown" data-seq="3"><div class="ps-desktop-nav-inner">
        {% for category in categories %}{% assign cat_href = category.url %}{% if cat_href == blank %}{% if category.slug != blank %}{% assign cat_href = "/collections/" | append: category.slug %}{% else %}{% assign cat_href = "#" %}{% endif %}{% endif %}{% unless cat_href contains "/pages/" %}{% assign ps_cat_dup_page = false %}{% for page in pages %}{% if page.slug == category.slug %}{% assign ps_cat_dup_page = true %}{% endif %}{% endfor %}{% unless ps_cat_dup_page %}{% assign cat_children_n = category.children | size %}{% if cat_children_n > 0 %}<div class="ps-nav-dropdown"><a href="{{ cat_href }}" class="ps-desktop-nav-link ps-nav-dropdown-trigger ps-nav-dropdown-trigger--link"><span>{{ category.name }}</span><img src="{{ theme_data.header_nav_chevron_icon | strip | default: 'https://files.easy-orders.net/1777884423218668962arrow%20for%20categories.svg' }}" alt="" class="ps-nav-chevron" width="12" height="12" /></a><div class="ps-nav-dropdown-panel">{% for child in category.children %}{% assign child_href = child.url %}{% if child_href == blank %}{% if child.slug != blank %}{% assign child_href = "/collections/" | append: child.slug %}{% else %}{% assign child_href = "#" %}{% endif %}{% endif %}<a href="{{ child_href }}">{{ child.name }}</a>{% endfor %}</div></div>{% else %}<a href="{{ cat_href }}" class="ps-desktop-nav-link">{{ category.name }}</a>{% endif %}{% endunless %}{% endunless %}{% endfor %}
        {% if ps_header_needs_pages_dd %}<div class="ps-nav-dropdown ps-nav-dropdown--pages"><button type="button" class="ps-desktop-nav-link ps-nav-dropdown-trigger ps-nav-dropdown-trigger--btn" aria-expanded="false" aria-haspopup="true" id="ps-header-pages-trigger"><span>{{ theme_data.header_pages_menu_label | strip | default: 'Pages' }}</span><img src="{{ theme_data.header_pages_chevron_icon | strip | default: 'https://files.easy-orders.net/1777885936858131198arrow%20down%20.svg' }}" alt="" class="ps-nav-chevron ps-nav-chevron--pages" width="12" height="12" /></button><div class="ps-nav-dropdown-panel ps-nav-dropdown-panel--pages" role="menu" aria-labelledby="ps-header-pages-trigger"><ul class="ps-pages-dropdown-list" role="none">{% for page in pages %}<li role="none"><a href="/pages/{{ page.slug }}" class="ps-pages-dropdown-link" role="menuitem">{{ page.title }}</a></li>{% endfor %}{% for category in categories %}{% assign cat_href = category.url %}{% if cat_href == blank %}{% if category.slug != blank %}{% assign cat_href = "/collections/" | append: category.slug %}{% else %}{% assign cat_href = "#" %}{% endif %}{% endif %}{% if cat_href contains "/pages/" %}{% assign ps_cat_dd_dup = false %}{% for page in pages %}{% if page.slug == category.slug %}{% assign ps_cat_dd_dup = true %}{% endif %}{% endfor %}{% unless ps_cat_dd_dup %}<li role="none"><a href="{{ cat_href }}" class="ps-pages-dropdown-link" role="menuitem">{{ category.name }}</a></li>{% endunless %}{% endif %}{% endfor %}</ul></div></div>{% endif %}
      </div></nav>
      <div class="ps-header-tools" data-anim="fadeInLeft" data-seq="2">
        <a href="/search" class="ps-icon-btn search-btn" aria-label="Search" data-eo="search-btn"><img src="{{ theme_data.header_search_icon | strip | default: 'https://files.easy-orders.net/1777884423228231659search%20icon%20for%20prduct%20cards%20.svg' }}" alt="" class="ps-icon-image" width="22" height="22" /></a>
        {% if is_register_active %}<a href="/register" class="ps-icon-btn register-btn" aria-label="Account" onclick="this.dispatchEvent(new CustomEvent('register-click',{bubbles:true})); return false;"><img width="22" height="22" class="ps-icon-image ps-account-icon" aria-hidden="true" src="https://files.easy-orders.net/1779102257908220564sx013.svg" alt="" loading="lazy" decoding="async" /></a>{% endif %}
        <button type="button" id="header-lang-btn" class="lang-btn ps-u-visually-hidden" onclick="this.dispatchEvent(new CustomEvent('lang-click',{bubbles:true,detail:{anchor:this}}))">Language</button>
        <button type="button" class="ps-icon-btn cart-btn" aria-label="Cart" onclick="this.dispatchEvent(new CustomEvent('cart-click',{bubbles:true}))"><img src="{{ theme_data.header_cart_icon | strip | default: 'https://files.easy-orders.net/1777884423251467919cart.svg' }}" alt="" class="ps-icon-image" width="22" height="22" /><span id="header-cart-count" class="ps-cart-count"{% if cart_count == 0 %} hidden{% endif %} aria-hidden="true">{{ cart_count }}</span></button>
      </div>
    </div>
  </header>
  <div class="ps-theme-layout-spacer" aria-hidden="true"></div>
  <div id="eo-mobile-overlay" class="ps-mobile-overlay"></div>
  <aside id="eo-mobile-menu" class="ps-mobile-menu" aria-label="Mobile menu"><div class="ps-mobile-menu__inner"><div class="ps-mobile-top"><a href="/" class="ps-logo ps-mobile-logo" aria-label="{{ store_name }}">{% if logo != blank %}<img src="{{ logo }}" alt="{{ store_name }}" />{% else %}<span class="ps-logo-text">{{ store_name }}</span>{% endif %}</a><button id="eo-mobile-close" class="ps-mobile-close" type="button" aria-label="Close menu"><img width="24" height="24" class="ps-close-icon" aria-hidden="true" src="https://files.easy-orders.net/1779102257874401432sx014.svg" alt="" loading="lazy" decoding="async" /></button></div>
    <nav class="ps-mobile-nav" aria-label="Mobile navigation"><div class="ps-mobile-nav-scroll">
      {% for category in categories %}{% assign cat_href = category.url %}{% if cat_href == blank %}{% if category.slug != blank %}{% assign cat_href = "/collections/" | append: category.slug %}{% else %}{% assign cat_href = "#" %}{% endif %}{% endif %}{% unless cat_href contains "/pages/" %}{% assign ps_cat_dup_page = false %}{% for page in pages %}{% if page.slug == category.slug %}{% assign ps_cat_dup_page = true %}{% endif %}{% endfor %}{% unless ps_cat_dup_page %}{% assign cat_children_n = category.children | size %}{% if cat_children_n > 0 %}<div class="ps-mobile-accordion"><button class="ps-mobile-link ps-accordion-trigger" type="button"><span>{{ category.name }}</span><img src="https://files.easy-orders.net/1778659562990248523prestig-header-mobile-accordion-chevron.svg" alt="" width="12" height="12" class="ps-arrow-icon" aria-hidden="true" /></button><div class="ps-accordion-panel"><a href="{{ cat_href }}" class="ps-mobile-sublink">All {{ category.name }}</a>{% for child in category.children %}{% assign child_href = child.url %}{% if child_href == blank %}{% if child.slug != blank %}{% assign child_href = "/collections/" | append: child.slug %}{% else %}{% assign child_href = "#" %}{% endif %}{% endif %}<a href="{{ child_href }}" class="ps-mobile-sublink">{{ child.name }}</a>{% endfor %}</div></div>{% else %}<a href="{{ cat_href }}" class="ps-mobile-link"><span>{{ category.name }}</span></a>{% endif %}{% endunless %}{% endunless %}{% endfor %}
      {% if ps_header_needs_pages_dd %}<div class="ps-mobile-accordion ps-mobile-accordion--pages"><button class="ps-mobile-link ps-mobile-link--pages-row ps-accordion-trigger" type="button"><span class="ps-mobile-link__label">{{ theme_data.header_pages_menu_label | strip | default: 'Pages' }}</span><img width="20" height="20" class="ps-mobile-pages-arrow" aria-hidden="true" src="https://files.easy-orders.net/1779102257880218891sx016.svg" alt="" loading="lazy" decoding="async" /></button><div class="ps-accordion-panel">{% for page in pages %}<a href="/pages/{{ page.slug }}" class="ps-mobile-sublink">{{ page.title }}</a>{% endfor %}{% for category in categories %}{% assign cat_href = category.url %}{% if cat_href == blank %}{% if category.slug != blank %}{% assign cat_href = "/collections/" | append: category.slug %}{% else %}{% assign cat_href = "#" %}{% endif %}{% endif %}{% if cat_href contains "/pages/" %}{% assign ps_cat_dd_dup = false %}{% for page in pages %}{% if page.slug == category.slug %}{% assign ps_cat_dd_dup = true %}{% endif %}{% endfor %}{% unless ps_cat_dd_dup %}<a href="{{ cat_href }}" class="ps-mobile-sublink">{{ category.name }}</a>{% endunless %}{% endif %}{% endfor %}</div></div>{% endif %}
      <a href="/search" class="ps-mobile-link ps-mobile-link--iconrow" data-eo="search-btn"><span>Search</span><img src="{{ theme_data.header_search_icon | strip | default: 'https://files.easy-orders.net/1777884423228231659search%20icon%20for%20prduct%20cards%20.svg' }}" alt="" class="ps-mobile-row-icon" width="20" height="20" loading="lazy" decoding="async" /></a>
      <div id="header-lang-mobile" class="ps-mobile-accordion ps-mobile-accordion--lang"><button class="ps-mobile-link ps-mobile-link--pages-row ps-accordion-trigger" type="button"><span class="ps-mobile-link__label">{{ theme_data.header_language_menu_label | strip | default: 'Language' }}</span><img width="20" height="20" class="ps-mobile-pages-arrow" aria-hidden="true" src="https://files.easy-orders.net/1779102257880218891sx016.svg" alt="" loading="lazy" decoding="async" /></button><div class="ps-accordion-panel">{% assign _ps_lang_opts = theme_data.header_language_options %}{% if _ps_lang_opts and _ps_lang_opts.size > 0 %}{% for opt in _ps_lang_opts %}{% assign _lo = opt.label | strip %}{% assign _lu = opt.url | strip %}{% if _lo != blank and _lu != blank %}<a href="{{ _lu }}" class="ps-mobile-sublink">{{ _lo }}</a>{% endif %}{% endfor %}{% else %}<button type="button" class="ps-mobile-sublink ps-mobile-sublink--btn lang-btn" onclick="this.dispatchEvent(new CustomEvent('lang-click',{bubbles:true,detail:{anchor:this}}))">{{ theme_data.header_language_fallback_label | strip | default: 'Change language' }}</button>{% endif %}</div></div>
    </div>{% if is_register_active %}<div class="ps-mobile-menu__footer"><a href="/register" class="ps-mobile-drawer-login register-btn" onclick="this.dispatchEvent(new CustomEvent('register-click',{bubbles:true})); return false;">{{ theme_data.header_drawer_login_label | default: 'Log in' }}</a></div>{% endif %}</nav></div></aside>
</div>
