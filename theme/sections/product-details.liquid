<div class="ab-pd ps-sr-scope" data-ps-pdp-details>{% if theme_data.brand_name %}<p class="ab-pd-brand" data-anim="fadeInUp" data-seq="0"><span class="ab-pd-brand-label">Brand:</span><span class="ab-pd-brand-value">{{ theme_data.brand_name }}</span></p>{% endif %}<h1 class="ab-pd-name" data-anim="fadeInUp" data-seq="1">{{ product_name }}</h1>{% liquid
  assign pd_list_price = price | plus: 0
  assign pd_deal_price = sale_price | plus: 0
%}<div class="ab-pd-price-rating-row" data-anim="fadeInUp" data-seq="2"><div class="ab-pd-price-group">{% if pd_deal_price > 0 and pd_list_price > 0 and pd_deal_price < pd_list_price %}<span class="ab-pd-price ab-pd-price-current">{{ sale_price }} {{ currency }}</span><span class="ab-pd-price-old">{{ price }} {{ currency }}</span>{% assign discount = pd_list_price | minus: pd_deal_price | times: 100 | divided_by: pd_list_price | floor %}<span class="ab-pd-discount-badge">{{ theme_data.sale_badge_label | strip | default: sale | default: "Save" }} -{{ discount }}%</span>{% else %}<span class="ab-pd-price ab-pd-price-current">{{ price }} {{ currency }}</span>{% endif %}</div>{% if rating > 0 %}{% liquid
  assign r_stars = rating | plus: 0
  if r_stars > 5
    assign r_stars = 5
  endif
  if r_stars < 0
    assign r_stars = 0
  endif
%}<div class="ab-pd-rating-group" role="img" aria-label="Rating {{ rating | round: 1 }} out of 5"><div class="ab-pd-stars" aria-hidden="true">{% for i in (1..5) %}{% assign prev = i | minus: 1 %}{% if r_stars >= i %}<img class="ab-pd-star-icon ab-pd-star-icon--on" src="https://files.easy-orders.net/1778659566243183115prestig-pdp-rating-star.svg" alt="" width="12" height="11" aria-hidden="true" />{% elsif r_stars > prev %}{% assign frac = r_stars | minus: prev %}<span class="ab-pd-star-slot"><img class="ab-pd-star-icon ab-pd-star-icon--off" src="https://files.easy-orders.net/1778659566243183115prestig-pdp-rating-star.svg" alt="" width="12" height="11" aria-hidden="true" /><span class="ab-pd-star-fill" style="width: calc(100% * {{ frac }});"><img class="ab-pd-star-icon ab-pd-star-icon--on" src="https://files.easy-orders.net/1778659566243183115prestig-pdp-rating-star.svg" alt="" width="12" height="11" aria-hidden="true" /></span></span>{% else %}<img class="ab-pd-star-icon ab-pd-star-icon--off" src="https://files.easy-orders.net/1778659566243183115prestig-pdp-rating-star.svg" alt="" width="12" height="11" aria-hidden="true" />{% endif %}{% endfor %}</div><span class="ab-pd-rating-paren">({{ rating | round: 1 }})</span></div>{% endif %}</div>{% if description and description != "" %}<p class="ab-pd-description" data-anim="fadeInUp" data-seq="3">{{ description }}</p>{% endif %}{% comment %} Wishlist & Compare buttons on the product detail page — dispatch toggle events handled by the storefront JS layer
  <div class="ab-pd-actions">
    <button
      class="ab-pd-wishlist-btn"
      type="button"
      aria-label="Add to wishlist"
      onclick="event.preventDefault();event.stopPropagation();this.dispatchEvent(new CustomEvent('toggle-wishlist',{bubbles:true,detail:{productId:'{{ product_id }}'}}));"
    >
      <img src="https://files.easy-orders.net/1778659562987257039prestig-header-icon-wishlist-heart.svg" alt="" width="24" height="24" aria-hidden="true" />
    </button>
    <button
      class="ab-pd-compare-btn"
      type="button"
      aria-label="Compare"
      onclick="event.preventDefault();event.stopPropagation();this.dispatchEvent(new CustomEvent('toggle-compare',{bubbles:true,detail:{productId:'{{ product_id }}'}}));"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 3 21 8 16 13"/><line x1="21" y1="8" x2="9" y2="8"/><polyline points="8 21 3 16 8 11"/><line x1="3" y1="16" x2="15" y2="16"/></svg>
    </button>
  </div>
  {% endcomment %}</div>
