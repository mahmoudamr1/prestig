<section class="ps-plist ps-sr-scope" data-ps-plist>{% if section_title %}<header class="ps-plist-header"><h2 class="ps-plist-title" data-anim="fadeInLeft" data-seq="0">{{ section_title }}</h2></header>{% endif %}<div class="ps-plist-viewport" data-ps-plist-viewport><div class="ps-plist-track" data-ps-plist-track>{% for product in products limit: 10 %}{% liquid
  assign color_variation = product.variations | where: "type", "color" | first
  assign image_variation = product.variations | where: "type", "image" | first
%}<a href="/products/{{ product.slug }}" class="ps-plist-card" data-ps-plist-card data-anim="cycle" data-cycle="{{ forloop.index0 }}" data-seq="{{ forloop.index0 | plus: 1 }}">{% if product.sale_price and product.sale_price < product.price %}{% assign discount = product.price | minus: product.sale_price | times: 100 | divided_by: product.price | floor %}<span class="ps-plist-badge ps-sale-badge">{{ theme_data.sale_badge_label | strip | default: sale | default: "Save" }} -{{ discount }}%</span>{% endif %}{% if product.product_theme_data.custom_badge_title and product.product_theme_data.custom_badge_title != "" %}<span class="ps-plist-badge ps-product-custom-badge">{{ product.product_theme_data.custom_badge_title }}</span>{% endif %}<div class="ps-plist-media"><img class="ps-plist-img-primary" src="{{ product.thumb }}" alt="{{ product.name }}" loading="lazy" />{% if product.images[0] %}<img class="ps-plist-img-hover" src="{{ product.images[0] }}" alt="{{ product.name }}" loading="lazy" />{% endif %}{% if product.disable_orders_for_no_stock %}<span class="ps-plist-add ps-product-stock-x" aria-label="Out of stock"><img class="ps-product-stock-x__icon" src="https://files.easy-orders.net/1773672706842218072x.svg" alt="" width="18" height="18" loading="lazy" decoding="async" aria-hidden="true" /></span>{% else %}<button type="button" class="ps-plist-add ps-product-quick-add" aria-label="Add to cart" onclick="event.preventDefault();event.stopPropagation();this.dispatchEvent(new CustomEvent('quick-add',{bubbles:true,detail:{productId:'{{ product.id }}'}}));"><img class="ps-product-plus-icon" src="https://files.easy-orders.net/1778659565003721866prestig-product-card-icon-quick-add-plus.svg" alt="" width="14" height="14" loading="lazy" aria-hidden="true" /></button>{% endif %}</div><div class="ps-plist-info"><div class="ps-plist-swatches">{% if color_variation and color_variation.props %}{% for prop in color_variation.props limit: 4 %}<span class="ps-plist-swatch" style="background: {{ prop.value }}" title="{{ prop.name }}"></span>{% endfor %}{% elsif image_variation and image_variation.props %}{% for prop in image_variation.props limit: 4 %}<span class="ps-plist-swatch ps-plist-swatch-image" title="{{ prop.name }}"><img src="{{ prop.value }}" alt="{{ prop.name }}" loading="lazy" /></span>{% endfor %}{% endif %}</div><p class="ps-plist-name">{{ product.name }}</p><div class="ps-plist-price-row">{% if product.sale_price and product.sale_price < product.price %}<span class="ps-plist-price-current">{{ product.sale_price }} {{ currency }}</span> <span class="ps-plist-price-old">{{ product.price }} {{ currency }}</span>{% else %}<span class="ps-plist-price-current">{{ product.price }} {{ currency }}</span>{% endif %}</div></div></a>{% endfor %}</div></div>{% if products and products.size > 1 %}<div class="ps-plist-footer"><div class="ps-plist-progress" aria-hidden="true"><span class="ps-plist-progress-fill" data-ps-plist-progress-fill></span></div><div class="ps-plist-arrows"><button type="button" class="ps-plist-arrow ps-plist-arrow-prev" data-ps-plist-prev aria-label="Previous"><img src="https://files.easy-orders.net/1778659566254837361prestig-ui-icon-chevron-left-24.svg" alt="" width="24" height="24" aria-hidden="true" /></button><button type="button" class="ps-plist-arrow ps-plist-arrow-next" data-ps-plist-next aria-label="Next"><img src="https://files.easy-orders.net/1778659566248894972prestig-ui-icon-chevron-right-24.svg" alt="" width="24" height="24" aria-hidden="true" /></button></div></div>{% endif %}</section>
