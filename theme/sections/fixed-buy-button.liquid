<section class="ps-sticky-buy" data-ps-sticky-buy>
  <div class="product_container ps-sticky-buy__container">
    <div class="ps-sticky-buy__inner">
      {% if thumb and thumb != "" %}
        <div class="ps-sticky-buy__left" data-anim="slideInLeft" data-seq="0">
          <div class="ps-sticky-buy__thumb">
            <img
              src="{{ thumb }}"
              alt="{{ product_name }}"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="ps-sticky-buy__meta">
            <p class="ps-sticky-buy__title">{{ product_name }}</p>
            <div class="ps-sticky-buy__price-row">
              {% if sale_price and sale_price < price %}
                <span class="ps-sticky-buy__price-current">{{ sale_price }} {{ currency }}</span>
                <span class="ps-sticky-buy__price-old">{{ price }} {{ currency }}</span>
              {% else %}
                <span class="ps-sticky-buy__price-only">{{ price }} {{ currency }}</span>
              {% endif %}
            </div>
          </div>
        </div>
      {% endif %}

      <div class="ps-sticky-buy__actions" data-anim="fadeInRight" data-seq="1">
        <div class="ps-sticky-buy__actions-row">
          {% unless hide_quantity %}
            <div class="ps-sticky-buy__qty">
              <div class="quantity_btn_container">
                <button
                  type="button"
                  onclick="this.dispatchEvent(new CustomEvent('increment-quantity',{bubbles:true}));"
                  {% if increase_disabled %}disabled{% endif %}
                  aria-label="Increase quantity"
                >
                  <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d="M11 11V5h2v6h6v2h-6v6h-2v-6H5v-2h6z"/></svg>
                </button>
                <p>{{ quantity }}</p>
                <button
                  type="button"
                  onclick="this.dispatchEvent(new CustomEvent('decrement-quantity',{bubbles:true}));"
                  aria-label="Decrease quantity"
                >
                  <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d="M5 11h14v2H5z"/></svg>
                </button>
              </div>
            </div>
          {% endunless %}

          <div class="ps-sticky-buy__btn-wrap">
            <button
              class="ps-sticky-buy__btn"
              type="button"
              {% if disabled %}disabled{% endif %}
              onclick="event.preventDefault();this.dispatchEvent(new CustomEvent('buy-now',{bubbles:true}));"
            >
              {{ buy_now_text }}
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
