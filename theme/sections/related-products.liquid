{% assign _pc_search = theme_data.product_card_search_icon_url | strip | default: 'https://files.easy-orders.net/1777960580107194333search%20icon%20for%20prduct%20cards%20.svg' %}
{% assign _pc_ch1 = theme_data.product_card_choose_label | default: '' | strip %}
{% if _pc_ch1 != blank %}
  {% assign _pc_choose = _pc_ch1 %}
{% else %}
  {% assign _pc_choose = theme_data.grid_products_choose_options_label | default: add | default: 'Choose options' | strip %}
{% endif %}
<section class="ab-plist ab-plist--related">

  <div class="product_container">

  <div class="ab-plist-header">

    {% if section_title %}

      <h2 class="ab-plist-title ab-reveal">{{ section_title }}</h2>

    {% endif %}

  </div>

  <div class="ab-plist-carousel-shell">

    <div class="ab-plist-arrows">

      <button class="ab-plist-arrow ab-plist-prev" type="button" aria-label="Previous">

        <img width="24" height="24" src="https://files.easy-orders.net/1779102257956421934sx025.svg" alt="" loading="lazy" decoding="async" />



      </button>

      <button class="ab-plist-arrow ab-plist-next" type="button" aria-label="Next">

        <img width="24" height="24" src="https://files.easy-orders.net/1779102257945901554sx026.svg" alt="" loading="lazy" decoding="async" />



      </button>

    </div>

    <div class="ab-plist-track">

    {% for product in products %}

      <a href="/products/{{ product.slug }}" class="ab-plist-card ab-reveal ps-store-card" style="animation-delay: {{ forloop.index | times: 0.04 }}s">

        <div class="ab-plist-media">
          <div class="ab-plist-badges">
            {% if product.sale_price and product.sale_price < product.price %}
              {% assign discount = product.price | minus: product.sale_price | times: 100 | divided_by: product.price | floor %}
              <span class="ps-product-badge ps-sale-badge">-{{ discount }}%</span>
            {% endif %}
            {% if product.product_theme_data.custom_badge_title != blank %}
              <span class="ps-product-badge ps-product-custom-badge">{{ product.product_theme_data.custom_badge_title | strip }}</span>
            {% endif %}
          </div>

          <img class="ab-plist-img-primary" src="{{ product.thumb }}" alt="{{ product.name }}" loading="lazy" />

          {% if product.images[0] %}

            <img class="ab-plist-img-hover" src="{{ product.images[0] }}" alt="{{ product.name }}" loading="lazy" />

          {% endif %}

          <button

            type="button"

            class="ps-card-qview"

            aria-label="Quick view"

            onclick="event.preventDefault();event.stopPropagation();this.dispatchEvent(new CustomEvent('quick-view',{bubbles:true,detail:{productId:'{{ product.id }}'}}));"

          >

            <img src="{{ _pc_search }}" alt="" class="ps-card-qview-img" width="20" height="20" loading="lazy" decoding="async" />

          </button>

          <button

            type="button"

            class="ps-card-choose ps-product-quick-add"

            aria-label="{{ _pc_choose }}"

            onclick="event.preventDefault();event.stopPropagation();this.dispatchEvent(new CustomEvent('quick-add',{bubbles:true,detail:{productId:'{{ product.id }}'}}));"

          >

            {{ _pc_choose }}

          </button>

          <button

            type="button"

            class="ps-card-mcart ps-product-quick-add"

            aria-label="Add to cart"

            onclick="event.preventDefault();event.stopPropagation();this.dispatchEvent(new CustomEvent('quick-add',{bubbles:true,detail:{productId:'{{ product.id }}'}}));"

          >

            <img src="{{ theme_data.header_cart_icon | strip | default: 'https://files.easy-orders.net/1777884423251467919cart.svg' }}" alt="" class="ps-icon-image ps-card-mcart-icon" width="20" height="20" loading="lazy" decoding="async" />

          </button>

        </div>



        <div class="ab-plist-info">

          {% if product.type != blank %}

            <p class="ps-store-card__cat">{{ product.type }}</p>

          {% endif %}

          <p class="ab-plist-name">{{ product.name }}</p>

          <div class="ab-plist-price-row">

            {% if product.sale_price and product.sale_price < product.price %}

              <span class="ab-plist-price ab-price-sale">{{ product.sale_price }} {{ currency }}</span>

              <span class="ab-price-old">{{ product.price }} {{ currency }}</span>

            {% else %}

              <span class="ab-plist-price">{{ product.price }} {{ currency }}</span>

            {% endif %}

          </div>

        </div>

      </a>

    {% endfor %}

  </div>

  </div>

  </div>

</section>

