<nav class="ab-breadcrumbs" aria-label="Breadcrumb">
  <ol class="ab-breadcrumbs-list">
    <li class="ab-breadcrumbs-item">
      <a href="/">{{ home_text }}</a>
      <span class="ab-breadcrumbs-sep" aria-hidden="true">
        <svg
          class="ps-mobile-pages-arrow ab-breadcrumbs-arrow"
          width="14"
          height="14"
          viewBox="0 0 20 20"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          focusable="false"
        >
          <path
            d="M7.5 3.74121L13.75 9.99121L7.5 16.2412"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </span>
    </li>
    {% for crumb in categories %}
      <li class="ab-breadcrumbs-item">
        <a href="/collections/{{ crumb.slug }}">{{ crumb.name }}</a>
        <span class="ab-breadcrumbs-sep" aria-hidden="true">
          <svg
            class="ps-mobile-pages-arrow ab-breadcrumbs-arrow"
            width="14"
            height="14"
            viewBox="0 0 20 20"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            focusable="false"
          >
            <path
              d="M7.5 3.74121L13.75 9.99121L7.5 16.2412"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </span>
      </li>
    {% endfor %}
    <li class="ab-breadcrumbs-item ab-breadcrumbs-current" aria-current="page">
      {{ product_name }}
    </li>
  </ol>
</nav>
