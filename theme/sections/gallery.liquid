<div class="ab-gallery ab-gallery--mix" data-ps-pdp-gallery>
  {% if images.size > 0 %}
    <div class="ab-gallery-grid-mix" role="list" aria-label="{{ product_name }} images">
      {% for image in images %}
        {% assign i0 = forloop.index0 %}
        {% assign mod3 = i0 | modulo: 3 %}
        <button
          type="button"
          role="listitem"
          class="ab-gallery-cell{% if mod3 == 0 %} ab-gallery-cell--span{% endif %}{% if image == mainImage %} ab-gallery-cell--active{% endif %}"
          data-src="{{ image }}"
          data-thumb-index="{{ i0 }}"
          data-gallery-open
          aria-label="View image {{ forloop.index }}"
        >
          {% if image contains '.mp4' %}
            <video
              src="{{ image }}"
              class="ab-gallery-cell-media"
              muted
              playsinline
              preload="metadata"
            ></video>
          {% else %}
            <img
              src="{{ image }}"
              alt="{{ product_name }}"
              class="ab-gallery-cell-media"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              width="800"
              height="800"
            />
          {% endif %}
        </button>
      {% endfor %}
    </div>
  {% endif %}

  {% assign ab_gallery_active_idx = 0 %}
  {% for image in images %}
    {% if image == mainImage %}
      {% assign ab_gallery_active_idx = forloop.index0 %}
    {% endif %}
  {% endfor %}

  <div class="ab-gallery-mobile">
    {% if images.size > 0 %}
      <div class="ab-gallery-slider" data-ab-gallery-slider>
        <div class="ab-gallery-slides">
          {% for image in images %}
            {% assign i0 = forloop.index0 %}
            <div
              class="ab-gallery-slide{% if image == mainImage %} is-active{% endif %}"
              data-slide-index="{{ i0 }}"
              data-src="{{ image }}"
            >
              <div class="ab-gallery-main" data-gallery-open>
                {% if image contains '.mp4' %}
                  <video
                    src="{{ image }}"
                    class="ab-gallery-main-media"
                    controls
                    playsinline
                    autoplay
                    muted
                    preload="metadata"
                  ></video>
                {% else %}
                  <img
                    {% if image == mainImage %}id="gallery-main-image" {% endif %}
                    src="{{ image }}"
                    alt="{{ product_name }}"
                    class="ab-gallery-main-media"
                    loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                    decoding="async"
                    width="1200"
                    height="1200"
                  />
                {% endif %}
                <button class="ab-gallery-zoom" type="button" aria-label="Zoom image">
                  <span class="ab-gallery-zoom-icon" aria-hidden="true"></span>
                </button>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}

    {% if images.size > 1 %}
      <nav class="ab-gallery-pager" aria-label="{{ product_name }} — gallery">
        <button type="button" class="ab-gallery-pager__btn" data-ab-gallery-prev aria-label="Previous image">
          <img width="24" height="24" aria-hidden="true" src="https://files.easy-orders.net/1779102257843364554sx010.svg" alt="" loading="lazy" decoding="async" />


        </button>
        <span class="ab-gallery-pager__counter" data-ab-gallery-counter aria-live="polite">{{ ab_gallery_active_idx | plus: 1 }} / {{ images.size }}</span>
        <button type="button" class="ab-gallery-pager__btn" data-ab-gallery-next aria-label="Next image">
          <img width="24" height="24" aria-hidden="true" src="https://files.easy-orders.net/1779102257941988629sx011.svg" alt="" loading="lazy" decoding="async" />


        </button>
      </nav>
    {% endif %}
  </div>

  <div class="ab-lightbox" data-lightbox>
    <div class="ab-lightbox-backdrop" data-lightbox-close tabindex="-1" aria-hidden="true"></div>
    <div class="ab-lightbox-shell">
      <div class="ab-lightbox-body">
        <img src="" alt="" class="ab-lightbox-img" data-lightbox-img />
      </div>
      <nav class="ab-lightbox-toolbar" aria-label="{{ product_name }} — preview">
        {% if images.size > 1 %}
          <button type="button" class="ab-lightbox-fab ab-lightbox-prev" data-lightbox-prev aria-label="Previous image">
            <img width="24" height="24" aria-hidden="true" src="https://files.easy-orders.net/1779102257843364554sx010.svg" alt="" loading="lazy" decoding="async" />


          </button>
        {% else %}
          <span class="ab-lightbox-fab-spacer" aria-hidden="true"></span>
        {% endif %}
        <button type="button" class="ab-lightbox-fab ab-lightbox-fab--close" data-lightbox-close aria-label="Close preview">
          <img width="24" height="24" aria-hidden="true" src="https://files.easy-orders.net/1779102257885285201sx012.svg" alt="" loading="lazy" decoding="async" />


        </button>
        {% if images.size > 1 %}
          <button type="button" class="ab-lightbox-fab ab-lightbox-next" data-lightbox-next aria-label="Next image">
            <img width="24" height="24" aria-hidden="true" src="https://files.easy-orders.net/1779102257941988629sx011.svg" alt="" loading="lazy" decoding="async" />


          </button>
        {% else %}
          <span class="ab-lightbox-fab-spacer" aria-hidden="true"></span>
        {% endif %}
      </nav>
      {% if images.size > 1 %}
        <span class="ps-u-sr-only" data-lightbox-counter aria-live="polite"></span>
      {% endif %}
    </div>
  </div>
</div>
