{% assign psc_show_decor = section_data.show_decor %}
{% if psc_show_decor == nil %}
  {% assign psc_show_decor = true %}
{% endif %}
{% assign _ar = section_data.aspect_ratio_desktop | default: 'squareish' %}

<section
  class="psc-compare ps-sr-scope"
  data-psc-split="{{ section_data.initial_split_percent | default: 50 }}"
  style="
    --psc-split: {{ section_data.initial_split_percent | default: 50 }};
    --psc-divider: {{ section_data.divider_color | default: '#000000' }};
    --psc-title: {{ section_data.title_color | default: '#2D3663' }};
    --psc-desc: {{ section_data.description_color | default: '#101010' }};
    --psc-accent: {{ section_data.caption_color | default: '#DA3C24' }};
  "
>
  {% if psc_show_decor %}
    <div class="psc-compare__decor" aria-hidden="true">
      {% if section_data.decor_top_left != blank %}
        <img
          class="psc-compare__decor-shape psc-compare__decor-shape--tl"
          src="{{ section_data.decor_top_left | default: 'https://files.easy-orders.net/1781195796814774195Vector_11.svg' }}"
          alt=""
          width="153"
          height="131"
          loading="lazy"
          decoding="async"
        />
      {% endif %}
      {% if section_data.decor_top_right != blank %}
        <img
          class="psc-compare__decor-shape psc-compare__decor-shape--tr"
          src="{{ section_data.decor_top_right | default: 'https://files.easy-orders.net/1781195796832811172Vector_10.svg' }}"
          alt=""
          width="200"
          height="80"
          loading="lazy"
          decoding="async"
        />
      {% endif %}
    </div>
  {% endif %}

  <div class="psc-compare__inner">
    <div class="psc-compare__shell psc-compare__shell--aspect-{{ _ar }}">
      <header class="psc-compare__header">
        {% if section_data.eyebrow != blank %}
          <p class="psc-compare__eyebrow" data-anim="fadeInDown" data-seq="0">{{ section_data.eyebrow }}</p>
        {% endif %}
        {% if section_data.heading != blank %}
          <h2 class="psc-compare__heading" data-anim="fadeInUp" data-seq="1">{{ section_data.heading }}</h2>
        {% endif %}
        {% if section_data.description != blank %}
          <p class="psc-compare__description" data-anim="fadeInUp" data-seq="2">{{ section_data.description }}</p>
        {% endif %}
      </header>

      <div
        class="psc-compare__frame"
        data-anim="fadeInScale"
        data-seq="3"
      >
        <div
          class="psc-compare__viewport"
          tabindex="0"
          role="group"
          aria-label="{{ section_data.heading | default: 'Product comparison' }}"
        >
          {% if section_data.image_left_url != blank and section_data.image_right_url != blank %}
            <div class="psc-compare__scene">
              <div class="psc-compare__media">
                <div class="psc-compare__layer psc-compare__layer--under">
                  <img
                    class="psc-compare__img"
                    src="{{ section_data.image_right_url }}"
                    alt="{{ section_data.image_right_alt }}"
                    loading="lazy"
                    decoding="async"
                    draggable="false"
                    width="1200"
                    height="900"
                  />
                  <div class="psc-compare__caption-slot psc-compare__caption-slot--under-right">
                    <div class="psc-compare__caption-block psc-compare__caption-block--right">
                      {% if section_data.caption_right_title != blank %}
                        <p class="psc-compare__caption-title">{{ section_data.caption_right_title }}</p>
                      {% endif %}
                      {% if section_data.caption_right_url != blank and section_data.caption_right_link_label != blank %}
                        <a class="psc-compare__caption-link" href="{{ section_data.caption_right_url }}">{{ section_data.caption_right_link_label }}</a>
                      {% endif %}
                    </div>
                  </div>
                </div>
                <div class="psc-compare__layer psc-compare__layer--over">
                  <img
                    class="psc-compare__img"
                    src="{{ section_data.image_left_url }}"
                    alt="{{ section_data.image_left_alt }}"
                    loading="lazy"
                    decoding="async"
                    draggable="false"
                    width="1200"
                    height="900"
                  />
                  <div class="psc-compare__caption-block psc-compare__caption-block--left">
                    {% if section_data.caption_left_title != blank %}
                      <p class="psc-compare__caption-title">{{ section_data.caption_left_title }}</p>
                    {% endif %}
                    {% if section_data.caption_left_url != blank and section_data.caption_left_link_label != blank %}
                      <a class="psc-compare__caption-link" href="{{ section_data.caption_left_url }}">{{ section_data.caption_left_link_label }}</a>
                    {% endif %}
                  </div>
                </div>

                <span class="psc-compare__divider" aria-hidden="true"></span>

                <button
                  type="button"
                  class="psc-compare__handle"
                  aria-valuemin="0"
                  aria-valuemax="100"
                  aria-valuenow="{{ section_data.initial_split_percent | default: 50 }}"
                  aria-label="Drag to compare photos"
                >
                  <span class="psc-compare__handle-grip" aria-hidden="true">
                    <span></span>
                    <span></span>
                    <span></span>
                  </span>
                </button>
              </div>
            </div>
          {% else %}
            <div class="psc-compare__empty">Add left and right image URLs in section settings.</div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  <style>
    .content_container:has(.psc-compare),
    .product_container:has(.psc-compare) {
      max-width: none !important;
      width: 100% !important;
      padding-left: 0 !important;
      padding-right: 0 !important;
      margin-left: 0 !important;
      margin-right: 0 !important;
      overflow: hidden;
    }

    .psc-compare {
      position: relative;
      isolation: isolate;
      box-sizing: border-box;
      width: 100%;
      max-width: none !important;
      margin-inline: 0;
      padding: clamp(40px, 6vw, 60px) 0;
      padding-inline: 0 !important;
      overflow: hidden;
      overflow-x: clip;
      overflow-y: clip;
      color: var(--psc-desc, #101010);
      background: var(--body-bg, var(--ps-page-bg, #fff9eb));
      -webkit-font-smoothing: antialiased;
    }

    .psc-compare__decor {
      position: absolute;
      left: 50%;
      top: 0;
      bottom: 0;
      z-index: 0;
      width: 100vw;
      max-width: 100vw;
      transform: translateX(-50%);
      pointer-events: none;
      user-select: none;
      overflow: hidden;
    }

    .psc-compare__decor-shape {
      position: absolute;
      display: block;
      width: auto;
      height: auto;
      max-width: none;
    }

    .psc-compare__decor-shape--tl {
      left: 0;
      top: clamp(48px, 8vw, 100px);
      width: clamp(80px, 10vw, 153px);
    }

    .psc-compare__decor-shape--tr {
      right: 0;
      top: clamp(24px, 4vw, 48px);
      width: clamp(100px, 14vw, 200px);
    }

    .psc-compare__inner {
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
      max-width: 1100px;
      margin: 0 auto;
      padding-inline: clamp(20px, 4vw, 50px);
      box-sizing: border-box;
    }

    .psc-compare__shell {
      width: 100%;
      max-width: none !important;
      margin: 0;
      padding: 0 !important;
    }

    .psc-compare__header {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: clamp(14px, 2.5vw, 22px);
      max-width: 488px;
      margin: 0 auto clamp(28px, 4vw, 40px);
      text-align: center;
    }

    .psc-compare__eyebrow {
      margin: 0;
      font-size: 0.6875rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      font-weight: 600;
      color: var(--psc-accent, #da3c24);
    }

    .psc-compare__heading {
      margin: 0;
      font-family: var(--ps-ff-primary, Asap), system-ui, sans-serif;
      font-size: clamp(32px, 5vw, 48px);
      font-weight: 700;
      line-height: 1.2;
      letter-spacing: 0;
      text-transform: none;
      color: var(--psc-title, #2d3663);
    }

    .psc-compare__description {
      margin: 0;
      font-family: var(--ps-ff-primary, Asap), system-ui, sans-serif;
      font-size: clamp(16px, 2.2vw, 20px);
      font-weight: 400;
      line-height: 1.4;
      color: var(--psc-desc, #101010);
    }

    .psc-compare__frame {
      width: 100%;
      max-width: 981px;
      margin: 0 auto;
      padding: clamp(12px, 2vw, 16px);
      border: 1px solid var(--ps-ink, #101010);
      border-radius: clamp(14px, 2.5vw, 20px);
      background: var(--ps-surface, #ffffff);
      box-shadow: -8px 8px 0 0 var(--ps-ink, #101010);
      box-sizing: border-box;
    }

    .psc-compare__viewport {
      outline: none;
      width: 100%;
      max-width: none !important;
      margin-inline: 0;
      padding-inline: 0 !important;
      border-radius: clamp(10px, 1.8vw, 16px);
      overflow: hidden;
    }

    .psc-compare__viewport:focus-visible {
      box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.15);
    }

    .psc-compare__scene {
      position: relative;
      width: 100%;
      max-width: none;
      border-radius: inherit;
      overflow: hidden;
      isolation: isolate;
      touch-action: pan-y !important;
      -webkit-overflow-scrolling: touch;
      -webkit-touch-callout: none;
      -webkit-user-select: none;
      user-select: none;
    }

    .psc-compare__media {
      position: relative;
      width: 100%;
      overflow: hidden;
      background: var(--ps-surface, #ffffff);
      cursor: ew-resize;
      aspect-ratio: 21 / 11;
      min-height: 220px;
      border-radius: inherit;
      z-index: 0;
    }

    .psc-compare__shell--aspect-ultrawide .psc-compare__media {
      aspect-ratio: 21 / 9;
    }

    .psc-compare__shell--aspect-wide .psc-compare__media {
      aspect-ratio: 16 / 9;
    }

    .psc-compare__shell--aspect-squareish .psc-compare__media {
      aspect-ratio: 4 / 3;
    }

    .psc-compare__layer {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    .psc-compare__layer--under .psc-compare__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
    }

    .psc-compare__layer--over {
      clip-path: inset(0 calc(100% - (var(--psc-split, 50) * 1%)) 0 0);
    }

    .psc-compare__caption-slot--under-right {
      position: absolute;
      inset: 0;
      z-index: 2;
      pointer-events: none;
      clip-path: inset(0 0 0 calc(var(--psc-split, 50) * 1%));
    }

    .psc-compare__layer--over .psc-compare__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
    }

    .psc-compare__divider {
      position: absolute;
      left: calc(var(--psc-split, 50) * 1%);
      top: 0;
      bottom: 0;
      width: 2px;
      background: var(--psc-divider, #000000);
      transform: translateX(-50%);
      pointer-events: none;
      z-index: 3;
      box-shadow: none;
    }

    .psc-compare__handle {
      position: absolute !important;
      left: calc(var(--psc-split, 50) * 1%) !important;
      top: 50% !important;
      z-index: 6;
      transform: translate(-50%, -50%) !important;
      box-sizing: border-box !important;
      width: 44px !important;
      min-width: 44px !important;
      max-width: 44px !important;
      height: 44px !important;
      min-height: 44px !important;
      max-height: 44px !important;
      margin: 0 !important;
      padding: 0 !important;
      border-radius: 50%;
      border: none;
      background: var(--psc-accent, #da3c24) !important;
      cursor: grab;
      display: inline-flex !important;
      align-items: center;
      justify-content: center;
      transition: transform 0.15s ease, filter 0.15s ease;
      filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.18));
      touch-action: manipulation !important;
      -webkit-tap-highlight-color: transparent;
    }

    .psc-compare__handle:active {
      cursor: grabbing;
    }

    @media (hover: hover) and (pointer: fine) {
      .psc-compare__handle:hover {
        transform: translate(-50%, -50%) scale(1.05) !important;
        filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.22));
      }
    }

    .psc-compare__handle-grip {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 3px;
      width: 100%;
      height: 100%;
      pointer-events: none;
    }

    .psc-compare__handle-grip span {
      display: block;
      width: 2px;
      height: 14px;
      border-radius: 1px;
      background: #ffffff;
    }

    .psc-compare__caption-block {
      position: absolute;
      top: clamp(12px, 2.4vw, 20px);
      bottom: auto;
      margin: 0;
      max-width: min(48%, calc(50vw - 1.5rem));
      z-index: 2;
      font-family: var(--ps-ff-primary, Asap), system-ui, sans-serif;
      pointer-events: none;
    }

    .psc-compare__caption-block--left {
      left: clamp(12px, 2.4vw, 22px);
      right: auto;
      text-align: left;
    }

    .psc-compare__caption-block--right {
      left: auto;
      right: clamp(12px, 2.4vw, 22px);
      text-align: right;
    }

    .psc-compare__caption-block * {
      pointer-events: none;
    }

    .psc-compare__caption-block a {
      pointer-events: auto;
      cursor: pointer;
    }

    .psc-compare__caption-title {
      margin: 0 0 0.25rem;
      font-size: clamp(13px, 1.8vw, 16px);
      letter-spacing: 0;
      text-transform: none;
      font-weight: 700;
      color: var(--psc-accent, #da3c24);
      line-height: 1.35;
      text-shadow: none;
    }

    .psc-compare__caption-link {
      display: inline-block;
      margin: 0;
      font-size: 0.7rem;
      letter-spacing: 0.02em;
      text-transform: none;
      font-weight: 500;
      color: var(--psc-accent, #da3c24);
      text-decoration: underline;
      text-underline-offset: 2px;
      border-bottom: none;
      padding-bottom: 0;
      opacity: 0.85;
      pointer-events: auto;
      text-shadow: none;
    }

    .psc-compare__caption-link:hover {
      opacity: 1;
    }

    .psc-compare__empty {
      padding: 3rem 1rem;
      text-align: center;
      font-family: var(--ps-ff-ui, Asap), system-ui, sans-serif;
      font-size: 0.9rem;
      color: #5c574f;
    }

    @media (max-width: 640px) {
      .psc-compare__decor-shape--tl {
        top: clamp(32px, 6vw, 64px);
        width: clamp(64px, 18vw, 100px);
      }

      .psc-compare__decor-shape--tr {
        width: clamp(72px, 20vw, 120px);
      }

      .psc-compare__frame {
        box-shadow: -5px 5px 0 0 var(--ps-ink, #101010);
      }
    }
  </style>
</section>
