{% assign wtts_headline = section_data.headline | default: 'What They Say for Us' %}
{% assign wtts_title_color = section_data.title_color | default: '#2D3679' %}
{% assign wtts_feature_image = section_data.feature_image | default: 'https://files.easy-orders.net/1777458784428286068.webp' %}
{% assign wtts_bg_yellow = section_data.bg_shape_top | default: 'https://files.easy-orders.net/1780942854170313214.webp' %}
{% assign wtts_bg_red = section_data.bg_shape_main | default: 'https://files.easy-orders.net/1780942856596138947.webp' %}
{% assign wtts_show_shapes = section_data.show_background_shapes %}
{% if wtts_show_shapes == nil %}
  {% assign wtts_show_shapes = true %}
{% endif %}
{% assign wtts_card_bg = section_data.card_bg | default: '#FFD265' %}
{% assign wtts_star_color = section_data.star_color | default: '#DA3C24' %}
{% assign wtts_quote_mark_color = section_data.quote_mark_color | default: '#DFBA62' %}
{% assign wtts_reviews = section_data.reviews %}

<section
  class="wtts"
  aria-labelledby="wtts-heading-{{ section.id }}"
  style="
    --wtts-title: {{ wtts_title_color }};
    --wtts-card-bg: {{ wtts_card_bg }};
    --wtts-star: {{ wtts_star_color }};
    --wtts-quote-mark: {{ wtts_quote_mark_color }};
  "
>
  {% if wtts_show_shapes %}
    <div class="wtts__decor" aria-hidden="true">
      {% if wtts_bg_yellow != blank %}
        <img
          class="wtts__decor-shape wtts__decor-shape--bg"
          src="{{ wtts_bg_yellow }}"
          alt=""
          width="1440"
          height="1005"
          loading="lazy"
          decoding="async"
        >
      {% endif %}
      {% if wtts_bg_red != blank %}
        <img
          class="wtts__decor-shape wtts__decor-shape--top"
          src="{{ wtts_bg_red }}"
          alt=""
          width="450"
          height="302"
          loading="lazy"
          decoding="async"
        >
      {% endif %}
    </div>
  {% endif %}

  <div class="wtts__inner">
    <h2 id="wtts-heading-{{ section.id }}" class="wtts__title">{{ wtts_headline }}</h2>

    <div class="wtts__layout">
      {% if wtts_feature_image != blank %}
        <figure class="wtts__figure">
          <img
            class="wtts__feature-img"
            src="{{ wtts_feature_image }}"
            alt=""
            width="497"
            height="484"
            loading="lazy"
            decoding="async"
          >
        </figure>
      {% endif %}

      {% if wtts_reviews and wtts_reviews.size > 0 %}
        <div class="wtts__cards">
          {% for review in wtts_reviews %}
            <article class="wtts__card">
              <div class="wtts__avatar-wrap">
                {% if review.avatar != blank %}
                  <img
                    class="wtts__avatar"
                    src="{{ review.avatar }}"
                    alt=""
                    width="100"
                    height="100"
                    loading="lazy"
                    decoding="async"
                  >
                {% else %}
                  <span class="wtts__avatar-fallback" aria-hidden="true"></span>
                {% endif %}
              </div>

              <div class="wtts__card-head">
                <span class="wtts__stars" aria-hidden="true">★★★★★</span>
                {% if review.title != blank %}
                  <h3 class="wtts__card-title">{{ review.title }}</h3>
                {% endif %}
              </div>

              {% if review.quote != blank %}
                <blockquote class="wtts__quote">
                  <p>{{ review.quote }}</p>
                </blockquote>
              {% endif %}

              {% if review.author != blank %}
                <footer class="wtts__author">{{ review.author }}</footer>
              {% endif %}

              <span class="wtts__quote-mark" aria-hidden="true">
                <svg width="30" height="30" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M8.5 22C5.5 22 3.5 19.5 3.5 16C3.5 10.5 7 6 12.5 4.5L13.5 6.5C9 8 6.5 11 6.5 14.5H8.5C11 14.5 13 16.5 13 19C13 21 11.5 22 8.5 22ZM21.5 22C18.5 22 16.5 19.5 16.5 16C16.5 10.5 20 6 25.5 4.5L26.5 6.5C22 8 19.5 11 19.5 14.5H21.5C24 14.5 26 16.5 26 19C26 21 24.5 22 21.5 22Z" fill="currentColor"/>
                </svg>
              </span>
            </article>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .content_container:has(.wtts),
  .product_container:has(.wtts) {
    max-width: none !important;
    width: 100% !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
    overflow: hidden;
  }

  .wtts {
    position: relative;
    isolation: isolate;
    box-sizing: border-box;
    width: 100%;
    overflow: hidden;
    padding: clamp(48px, 6vw, 60px) 0 clamp(64px, 8vw, 80px);
    color: var(--ps-ink, #101010);
    background: var(--ps-cream, #fef7e6);
  }

  .wtts__decor {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    z-index: 0;
    width: 100vw;
    max-width: 100vw;
    transform: translateX(-50%);
    pointer-events: none;
    user-select: none;
    overflow: hidden;
  }

  .wtts__decor-shape {
    position: absolute;
    display: block;
    max-width: none;
  }

  /* Figma 19:1504 — yellow/cream fill, full viewport width */
  .wtts__decor-shape--bg {
    left: 0;
    top: clamp(72px, 10.2vw, 147px);
    width: 100vw;
    min-width: 100vw;
    height: auto;
    object-fit: cover;
    object-position: center top;
  }

  /* Figma 19:1505 — red line, top-left from viewport edge (y ≈ -45 clipped) */
  .wtts__decor-shape--top {
    left: 0;
    top: 0;
    width: clamp(220px, 31.25vw, 450px);
    height: auto;
    object-fit: contain;
    object-position: left top;
  }

  .wtts__inner {
    position: relative;
    z-index: 2;
    max-width: 1100px;
    width: 100%;
    margin-inline: auto;
    padding-inline: clamp(20px, 4vw, 50px);
    box-sizing: border-box;
  }

  .wtts__title {
    margin: 0 0 48px;
    text-align: center;
    font-family: var(--ps-ff-ui, var(--ps-ff-primary)), sans-serif;
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0;
    color: var(--wtts-title, #2d3679);
  }

  .wtts__layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 40px;
    align-items: end;
  }

  .wtts__figure {
    margin: 0;
    max-width: 497px;
    width: 100%;
    justify-self: center;
  }

  .wtts__feature-img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 497 / 484;
    object-fit: cover;
    border-radius: 0;
  }

  .wtts__cards {
    display: flex;
    flex-direction: column;
    gap: 50px;
    max-width: 563px;
    width: 100%;
    margin-inline: auto;
  }

  /* Figma 19:1511 / 19:1521 / 19:1531 — review card */
  .wtts__card {
    position: relative;
    width: 100%;
    max-width: 403px;
    margin: 35px 0 0;
    padding: 32px 35px 36px;
    background: var(--wtts-card-bg, #ffd265);
    border-radius: 10px;
    box-sizing: border-box;
    font-family: var(--ps-ff-ui, var(--ps-ff-primary)), sans-serif;
  }

  .wtts__card:nth-child(2) {
    margin-inline-start: clamp(0px, 11.11vw, 160px);
  }

  .wtts__card:nth-child(3) {
    margin-inline-start: 0;
  }

  .wtts__avatar-wrap {
    position: absolute;
    top: -35px;
    right: -35px;
    width: 100px;
    height: 100px;
    border: 4px solid #ffffff;
    border-radius: 50%;
    background: #ffffff;
    overflow: hidden;
    z-index: 1;
    box-sizing: border-box;
  }

  .wtts__avatar {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .wtts__avatar-fallback {
    display: block;
    width: 100%;
    height: 100%;
    background: var(--ps-surface-subtle, #f5f5f5);
  }

  /* Stars x=35 y=32 + title x=165 y=35.6 on one row */
  .wtts__card-head {
    display: grid;
    grid-template-columns: 100px minmax(0, 1fr);
    align-items: center;
    column-gap: 30px;
    margin: 0 0 22px;
    padding-inline-end: 58px;
  }

  .wtts__stars {
    grid-column: 1;
    font-size: 20px;
    line-height: 28px;
    letter-spacing: 0;
    color: var(--wtts-star, #da3c24);
    white-space: nowrap;
  }

  .wtts__card-title {
    grid-column: 2;
    margin: 0;
    font-size: 14px;
    font-weight: 700;
    line-height: 16.8px;
    letter-spacing: 0;
    color: var(--ps-ink, #101010);
  }

  /* Quote x=35 y=77, width ~286 */
  .wtts__quote {
    margin: 0 0 18px;
    max-width: 286px;
    font-size: 14px;
    font-weight: 400;
    line-height: 19.6px;
    letter-spacing: 0;
    color: var(--ps-ink, #101010);
  }

  .wtts__quote p {
    margin: 0;
  }

  /* Author x=35 y≈205 */
  .wtts__author {
    margin: 0;
    max-width: 286px;
    font-size: 14px;
    font-weight: 400;
    line-height: 16px;
    letter-spacing: 0;
    color: var(--ps-ink, #101010);
  }

  /* Quote icon — tan/gold on yellow card (Figma 19:1517–19:1520) */
  .wtts__quote-mark {
    position: absolute;
    left: 30px;
    bottom: 0;
    width: 30px;
    height: 30px;
    color: var(--wtts-quote-mark, #dfba62);
    pointer-events: none;
  }

  .wtts__quote-mark svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  @media (min-width: 1024px) {
    .wtts__layout {
      grid-template-columns: minmax(0, 497px) minmax(0, 563px);
      gap: 40px;
      align-items: center;
      justify-content: center;
    }

    .wtts__figure {
      justify-self: end;
      align-self: center;
    }

    .wtts__cards {
      justify-self: start;
      margin-inline: 0;
    }
  }

  @media (max-width: 767px) {
    .wtts {
      padding-top: 48px;
      padding-bottom: 64px;
    }

    .wtts__inner {
      padding-inline: 20px;
    }

    .wtts__decor-shape--top {
      width: clamp(180px, 48vw, 280px);
    }

    .wtts__title {
      margin-bottom: 32px;
    }

    .wtts__card {
      max-width: none;
      margin-top: 28px;
      padding: 28px 24px 32px;
    }

    .wtts__card-head {
      grid-template-columns: 88px minmax(0, 1fr);
      column-gap: 16px;
      margin-bottom: 18px;
      padding-inline-end: 48px;
    }

    .wtts__stars {
      font-size: 18px;
      line-height: 24px;
    }

    .wtts__quote,
    .wtts__author {
      max-width: none;
    }

    .wtts__card:nth-child(2) {
      margin-inline-start: 0;
    }

    .wtts__avatar-wrap {
      top: -28px;
      right: 16px;
      width: 80px;
      height: 80px;
    }
  }

  html.ps-app-lang-ar .wtts__avatar-wrap,
  [dir="rtl"] .wtts__avatar-wrap {
    right: auto;
    left: -35px;
  }

  html.ps-app-lang-ar .wtts__card:nth-child(2),
  [dir="rtl"] .wtts__card:nth-child(2) {
    margin-inline-start: 0;
    margin-inline-end: clamp(0px, 11vw, 160px);
  }

  html.ps-app-lang-ar .wtts__quote-mark,
  [dir="rtl"] .wtts__quote-mark {
    left: auto;
    right: 30px;
  }

  @media (max-width: 767px) {
    html.ps-app-lang-ar .wtts__avatar-wrap,
    [dir="rtl"] .wtts__avatar-wrap {
      left: 16px;
    }

    html.ps-app-lang-ar .wtts__quote-mark,
    [dir="rtl"] .wtts__quote-mark {
      right: 24px;
    }
  }
</style>
