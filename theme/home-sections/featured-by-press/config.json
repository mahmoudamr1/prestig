      "description": "Press logo + testimonial (desktop grid / mobile swipe)",
      "default": [
        {
          "logo_url": "https://sleek-theme-demo.myshopify.com/cdn/shop/files/press-item-1.png?v=1717030572&width=1100",
          "logo_alt": "Press feature 1",
          "quote": "Also the customer service is phenomenal. I would purchase again."
        },
        {
          "logo_url": "https://sleek-theme-demo.myshopify.com/cdn/shop/files/press-item-2.png?v=1717030572&width=1100",
          "logo_alt": "Press feature 2",
          "quote": "Great product line. Very attentive staff to deal with."
        },
        {
          "logo_url": "https://sleek-theme-demo.myshopify.com/cdn/shop/files/press-item-3.png?v=1717030573&width=1100",
          "logo_alt": "Press feature 3",
