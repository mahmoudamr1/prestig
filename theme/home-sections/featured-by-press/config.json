{
  "icon": "https://api.iconify.design/lucide:newspaper.svg",
  "label": "Featured by press",
  "section_schema": [
    {
      "name": "heading",
      "type": "string",
      "default": "Featured by Press",
      "description": "Centered section title"
    },
    {
      "name": "bg_color",
      "type": "color",
      "default": "#ffffff",
      "description": "Section background"
    },
    {
      "name": "heading_color",
      "type": "color",
      "default": "#111111",
      "description": "Title color"
    },
    {
      "name": "quote_color",
      "type": "color",
      "default": "#4b4b4b",
      "description": "Quote text color"
    },
    {
      "name": "divider_color",
      "type": "color",
      "default": "#e8e8e8",
      "description": "Bottom border line color"
    },
    {
      "name": "show_divider",
      "type": "boolean",
      "default": true,
      "description": "Show divider under the section"
    },
    {
