{% if section_data.badges and section_data.badges.size > 0 %}
<section
  class="ps-trust-pills"
  style="
    --ps-tp-bg: {{ section_data.bg_color | default: '#ffffff' }};
    --ps-tp-pill-bg: {{ section_data.pill_bg | default: '#ffffff' }};
    --ps-tp-pill-border: {{ section_data.pill_border | default: '#e0e0e0' }};
    --ps-tp-icon-circle: {{ section_data.icon_circle_bg | default: '#f0f0f0' }};
    --ps-tp-icon: {{ section_data.icon_color | default: '#111111' }};
    --ps-tp-text: {{ section_data.text_color | default: '#111111' }};
  "
>
  <div class="ps-trust-pills__inner">
    <div class="ps-trust-pills__row" role="list">
      {% for badge in section_data.badges %}
        {% if badge.label != blank %}
          <div class="ps-trust-pills__cell" role="listitem">
            {% if badge.link_url != blank %}
              <a class="ps-trust-pills__pill" href="{{ badge.link_url }}">
                <span class="ps-trust-pills__check" aria-hidden="true">
                  <svg class="ps-trust-pills__check-svg" width="12" height="10" viewBox="0 0 12 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M1.5 5.2L4.3 8L10.5 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                <span class="ps-trust-pills__label">{{ badge.label }}</span>
              </a>
            {% else %}
              <span class="ps-trust-pills__pill">
                <span class="ps-trust-pills__check" aria-hidden="true">
                  <svg class="ps-trust-pills__check-svg" width="12" height="10" viewBox="0 0 12 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M1.5 5.2L4.3 8L10.5 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                <span class="ps-trust-pills__label">{{ badge.label }}</span>
              </span>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .ps-trust-pills {
    box-sizing: border-box;
    width: 100%;
    background: var(--ps-tp-bg, #ffffff);
    padding: clamp(1rem, 2.5vw, 1.5rem) clamp(1rem, 4vw, 1.75rem);
    font-family: var(--ps-ff-primary), var(--ps-ff-ui), system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  .ps-trust-pills__inner {
    max-width: 1200px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .ps-trust-pills__row {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.625rem 0.875rem;
    box-sizing: border-box;
  }

  .ps-trust-pills__cell {
    flex: 0 0 auto;
    box-sizing: border-box;
  }

  .ps-trust-pills__pill {
    display: inline-flex;
    flex-direction: row;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    padding: 0.5rem 1rem;
    min-height: 2.5rem;
    border-radius: 624.9375rem;
    background: var(--ps-tp-pill-bg, #ffffff);
    border: 1px solid var(--ps-tp-pill-border, #e0e0e0);
    color: var(--ps-tp-text, #111111);
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.25;
    text-decoration: none;
    box-sizing: border-box;
    cursor: default;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  a.ps-trust-pills__pill {
    cursor: pointer;
  }

  @media (hover: hover) {
    a.ps-trust-pills__pill:hover {
      border-color: color-mix(in srgb, var(--ps-tp-pill-border, #e0e0e0) 70%, var(--ps-tp-text, #111));
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }
  }

  a.ps-trust-pills__pill:focus-visible {
    outline: 2px solid var(--ps-tp-text, #111111);
    outline-offset: 2px;
  }

  .ps-trust-pills__check {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--ps-tp-icon-circle, #f0f0f0);
    color: var(--ps-tp-icon, #111111);
  }

  .ps-trust-pills__check-svg {
    display: block;
    margin-top: 1px;
  }

  .ps-trust-pills__label {
    white-space: nowrap;
  }

  @media (max-width: 767px) {
    .ps-trust-pills__row {
      flex-wrap: nowrap;
      justify-content: flex-start;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: thin;
      margin-inline: calc(-1 * clamp(1rem, 4vw, 1.75rem));
      padding-inline: clamp(1rem, 4vw, 1.75rem);
      padding-bottom: 0.25rem;
      gap: 0.5rem;
    }

    .ps-trust-pills__cell {
      scroll-snap-align: start;
    }

    .ps-trust-pills__label {
      white-space: normal;
      max-width: 70vw;
    }
  }
</style>
{% endif %}
