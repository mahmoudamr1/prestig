{% if section_data.reviews and section_data.reviews.size > 0 %}
<div
  class="ps-rev-carousel-shell ps-sr-scope"
  style="
    --ps-rc-heading: {{ section_data.heading_color | default: '#111111' }};
    --ps-rc-radius: {{ section_data.card_radius | default: 18 }}px;
    --ps-rc-gap: {{ section_data.track_gap | default: 20 }}px;
  "
>
<div class="ps-rev-carousel-slot">
<section
  class="ps-rev-carousel"
  data-ps-rev-showcase
>
  <div class="ps-rev-carousel__inner">
    <div class="ps-rev-carousel__head" data-anim="fadeInDown" data-seq="0">
      {% if section_data.heading != blank %}
        <h2 class="ps-rev-carousel__title" data-anim="fadeInUp" data-seq="1">{{ section_data.heading }}</h2>
      {% endif %}
      <div class="ps-rev-carousel__nav" aria-label="{{ section_data.heading | default: 'Reviews' }}" data-anim="fadeInLeft" data-seq="2">
        <button
          type="button"
          class="ps-rev-carousel__btn ps-rev-carousel__btn--prev"
          data-ps-rev-prev
          aria-label="{{ section_data.prev_label | default: 'Previous reviews' | escape }}"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <polyline points="15 18 9 12 15 6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button
          type="button"
          class="ps-rev-carousel__btn ps-rev-carousel__btn--next"
          data-ps-rev-next
          aria-label="{{ section_data.next_label | default: 'Next reviews' | escape }}"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <polyline points="9 18 15 12 9 6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>

    <div class="ps-rev-carousel__viewport">
      <div
        class="ps-rev-carousel__track"
        data-ps-rev-carousel
        tabindex="0"
        role="region"
        {% if section_data.heading != blank %}aria-label="{{ section_data.heading | escape }}"{% endif %}
      >
        {% for rev in section_data.reviews %}
          {% assign rc_p = rev.product %}
          {% assign rc_p_thumb = '' %}
          {% assign rc_p_name = '' %}
          {% assign rc_p_href = '' %}
          {% if rc_p != blank %}
            {% if rc_p.thumb != blank %}
              {% assign rc_p_thumb = rc_p.thumb %}
            {% elsif rc_p.image != blank %}
              {% assign rc_p_thumb = rc_p.image %}
            {% endif %}
            {% if rc_p.name != blank %}
              {% assign rc_p_name = rc_p.name %}
            {% endif %}
            {% if rc_p.url != blank %}
              {% assign rc_p_href = rc_p.url %}
            {% elsif rc_p.slug != blank %}
              {% assign rc_p_href = '/products/' | append: rc_p.slug %}
            {% endif %}
          {% endif %}
          {% if rc_p_thumb == blank and rev.product_thumb != blank %}
            {% assign rc_p_thumb = rev.product_thumb %}
          {% endif %}
          {% if rc_p_name == blank and rev.product_name != blank %}
            {% assign rc_p_name = rev.product_name %}
          {% endif %}
          {% if rc_p_href == blank and rev.product_url != blank %}
            {% assign rc_p_href = rev.product_url %}
          {% endif %}
          {% assign rc_pid = rev.product_id | default: '' | strip %}
          {% if rc_pid == blank and rc_p != blank and rc_p.id != blank %}
            {% assign rc_pid = rc_p.id | strip %}
          {% endif %}
          {% assign rc_show_product = false %}
          {% if rc_pid == blank %}
            {% if rc_p_thumb != blank or rc_p_name != blank %}
              {% assign rc_show_product = true %}
            {% endif %}
          {% endif %}
          <article class="ps-rev-carousel__card" data-anim="cycle" data-cycle="{{ forloop.index0 }}" data-seq="{{ forloop.index0 }}">
            {% if rev.photo_url != blank %}
              <div class="ps-rev-carousel__media">
                <img
                  class="ps-rev-carousel__photo"
                  src="{{ rev.photo_url }}"
                  alt="{% if rev.reviewer_name != blank %}{{ rev.reviewer_name }} review{% else %}Review{% endif %}"
                  width="400"
                  height="280"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  decoding="async"
                />
              </div>
            {% endif %}
            <div class="ps-rev-carousel__body">
              {% if rev.reviewer_name != blank or rev.verified_label != blank %}
                <p class="ps-rev-carousel__meta">
                  {% if rev.reviewer_name != blank %}
                    <span class="ps-rev-carousel__name">{{ rev.reviewer_name }}</span>
                  {% endif %}
                  {% if rev.verified_label != blank %}
                    <span class="ps-rev-carousel__verified">{{ rev.verified_label }}</span>
                  {% endif %}
                </p>
              {% endif %}
              {% if rev.body != blank %}
                <p class="ps-rev-carousel__text">{{ rev.body }}</p>
              {% endif %}
              {% if rc_pid != blank %}
                <div class="ps-rev-carousel__rule" role="presentation"></div>
                <div
                  class="ps-rev-carousel__product-hs eo-hs"
                  data-eo-hs-entity="products"
                  data-eo-hs-ids="{{ rc_pid }}"
                >
                  <div class="ps-rev-carousel__product-mount" data-eo-hs-mount>
                    <div class="eo-hs-skeleton eo-hs-skeleton--product" aria-hidden="true"></div>
                  </div>
                </div>
              {% elsif rc_show_product %}
                <div class="ps-rev-carousel__rule" role="presentation"></div>
                {% if rc_p_href != blank %}
                  <a class="ps-rev-carousel__product" href="{{ rc_p_href }}">
                    {% if rc_p_thumb != blank %}
                      <img
                        class="ps-rev-carousel__pthumb"
                        src="{{ rc_p_thumb }}"
                        alt="{{ rc_p_name | default: 'Product' }}"
                        width="48"
                        height="48"
                        loading="lazy"
                        decoding="async"
                      />
                    {% endif %}
                    {% if rc_p_name != blank %}
                      <span class="ps-rev-carousel__pname">{{ rc_p_name }}</span>
                    {% endif %}
                  </a>
                {% else %}
                  <div class="ps-rev-carousel__product ps-rev-carousel__product--static">
                    {% if rc_p_thumb != blank %}
                      <img
                        class="ps-rev-carousel__pthumb"
                        src="{{ rc_p_thumb }}"
                        alt="{{ rc_p_name | default: 'Product' }}"
                        width="48"
                        height="48"
                        loading="lazy"
                        decoding="async"
                      />
                    {% endif %}
                    {% if rc_p_name != blank %}
                      <span class="ps-rev-carousel__pname">{{ rc_p_name }}</span>
                    {% endif %}
                  </div>
                {% endif %}
              {% endif %}
            </div>
          </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
</div>
</div>

<style>
  /* أب أول: خلفية بعرض الصف. أب ثاني: كونتينر الصفحة (max-width + حواف). Full-bleed: theme/style.css */
  .ps-rev-carousel-shell {
    box-sizing: border-box;
    width: 100%;
    padding-top: clamp(2rem, 5vw, 3.5rem);
    padding-bottom: clamp(2rem, 5vw, 3.5rem);
    background: #f3eeea;
    font-family: var(--ps-ff-primary), var(--ps-ff-ui), system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  .ps-rev-carousel-slot {
    --bs-gutter-x: 2rem;
    --ps-rc-inline-pad: calc(var(--bs-gutter-x) * 0.5);
    box-sizing: border-box;
    width: 100%;
    max-width: none;
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--ps-rc-inline-pad);
    padding-right: var(--ps-rc-inline-pad);
  }

  .ps-rev-carousel {
    box-sizing: border-box;
    width: 100%;
    margin: 0;
    padding: 0;
    background: transparent;
  }

  .ps-rev-carousel__inner {
    width: 100%;
    max-width: none;
    margin: 0;
    box-sizing: border-box;
  }

  .ps-rev-carousel__head {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: clamp(1.25rem, 3vw, 2rem);
    flex-wrap: wrap;
  }

  .ps-rev-carousel__title {
    margin: 0;
    font-size: clamp(1.25rem, 3vw, 1.625rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--ps-rc-heading, var(--product-name-text, #111111));
  }

  .ps-rev-carousel__nav {
    display: none;
    flex-direction: row;
    align-items: center;
    gap: 8px;
  }

  @media (min-width: 1025px) {
    .ps-rev-carousel__nav {
      display: flex;
    }
  }

  .ps-rev-carousel__btn {
    width: 40px;
    height: 40px;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.06);
    background: #e8e4df;
    color: var(--product-name-text, #111111);
    cursor: pointer;
    box-sizing: border-box;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  @media (hover: hover) {
    .ps-rev-carousel__btn:hover {
      background: #ddd8d2;
      border-color: rgba(0, 0, 0, 0.1);
    }
  }

  .ps-rev-carousel__btn:focus-visible {
    outline: 2px solid var(--product-name-text, #111111);
    outline-offset: 2px;
  }

  .ps-rev-carousel__viewport {
    margin-inline: calc(-1 * var(--ps-rc-inline-pad));
    padding-inline: var(--ps-rc-inline-pad);
    box-sizing: border-box;
  }

  @media (min-width: 1025px) {
    .ps-rev-carousel__viewport {
      margin-inline: 0;
      padding-inline: 0;
    }
  }

  .ps-rev-carousel__track {
    display: flex;
    flex-direction: row;
    gap: var(--ps-rc-gap, 20px);
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    box-sizing: border-box;
    outline: none;
    padding-bottom: 0.25rem;
  }

  .ps-rev-carousel__track::-webkit-scrollbar {
    display: none;
    width: 0;
    height: 0;
  }

  @media (min-width: 1025px) {
    .ps-rev-carousel__track {
      cursor: grab;
      user-select: none;
    }

    .ps-rev-carousel__track:active {
      cursor: grabbing;
    }
  }

  .ps-rev-carousel__card {
    flex: 0 0 min(300px, 82vw);
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    border-radius: var(--ps-rc-radius, 18px);
    overflow: hidden;
    background: #ffffff;
    box-sizing: border-box;
    min-height: 0;
  }

  @media (min-width: 1025px) {
    .ps-rev-carousel__card {
      flex: 0 0 clamp(280px, 30vw, 400px);
    }
  }

  .ps-rev-carousel__media {
    position: relative;
    flex: 0 0 auto;
    width: 100%;
    {% comment %} aspect-ratio: 4 / 3; {% endcomment %}
    min-height: 160px;
    background: #ebe8e4;
    overflow: hidden;
  }

  .ps-rev-carousel__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .ps-rev-carousel__body {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    padding: 1.125rem 1.125rem 1.25rem;
    box-sizing: border-box;
    gap: 0.65rem;
  }

  .ps-rev-carousel__meta {
    margin: 0;
    font-size: clamp(0.8125rem, 0.32vw + 0.74rem, 0.9375rem);
    line-height: 1.4;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem 0.5rem;
  }

  .ps-rev-carousel__name {
    font-weight: 700;
    font-size: clamp(1rem, 0.48vw + 0.86rem, 1.125rem);
    line-height: 1.35;
    color: var(--product-name-text, #111111);
  }

  .ps-rev-carousel__verified {
    font-weight: 400;
    font-size: clamp(0.75rem, 0.28vw + 0.68rem, 0.875rem);
    line-height: 1.4;
    color: var(--body-text, #333333);
    opacity: 0.72;
  }

  .ps-rev-carousel__text {
    margin: 0;
    font-size: clamp(0.875rem, 0.38vw + 0.78rem, 1rem);
    font-weight: 400;
    line-height: 1.55;
    color: var(--body-text, #333333);
    flex: 1 1 auto;
  }

  .ps-rev-carousel__rule {
    height: 0;
    margin: 0.25rem 0 0;
    border: 0;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .ps-rev-carousel__product {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.65rem;
    margin-top: 0.125rem;
    text-decoration: none;
    color: inherit;
    min-width: 0;
  }

  .ps-rev-carousel__product--static {
    pointer-events: none;
  }

  .ps-rev-carousel__pthumb {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 8px;
    object-fit: cover;
    display: block;
    background: #f0f0f0;
  }

  .ps-rev-carousel__pname {
    font-size: clamp(0.8125rem, 0.32vw + 0.74rem, 0.9375rem);
    font-weight: 700;
    line-height: 1.35;
    color: var(--product-name-text, #111111);
    text-align: left;
  }

  .ps-rev-carousel__product:focus-visible .ps-rev-carousel__pname {
    text-decoration: underline;
  }

  .ps-rev-carousel__product-mount .eo-hs-card--product:focus-visible .eo-hs-card__title {
    text-decoration: underline;
  }

  /* Hydrated product row (EasyOrders `data-eo-hs-*` — same contract as shop-the-look). */
  .ps-rev-carousel__product-hs {
    margin-top: 0.125rem;
    min-width: 0;
  }

  .ps-rev-carousel__product-mount {
    min-width: 0;
  }

  .ps-rev-carousel__product-mount .eo-hs-skeleton--product {
    min-height: 48px;
    border-radius: 8px;
    background: linear-gradient(110deg, #ece8e2 8%, #f5f2ee 18%, #ece8e2 33%);
    background-size: 200% 100%;
    animation: ps-rc-hs-shimmer 1.2s ease-in-out infinite;
  }

  .ps-rev-carousel__product-mount.eo-hs-loading .eo-hs-skeleton--product {
    opacity: 1;
  }

  .ps-rev-carousel__product-mount .eo-hs-card--product {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.65rem;
    padding: 0;
    margin: 0;
    border: none;
    background: transparent;
    box-shadow: none;
    border-radius: 0;
    text-decoration: none;
    color: inherit;
    min-width: 0;
  }

  .ps-rev-carousel__product-mount .eo-hs-card--product:hover {
    transform: none;
    background: transparent;
  }

  .ps-rev-carousel__product-mount .eo-hs-card--product .eo-hs-card__media {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    min-height: 48px;
    border-radius: 8px;
    overflow: hidden;
  }

  .ps-rev-carousel__product-mount .eo-hs-card--product .eo-hs-card__media--empty {
    width: 48px;
    height: 48px;
    min-height: 48px;
  }

  .ps-rev-carousel__product-mount .eo-hs-card--product .eo-hs-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ps-rev-carousel__product-mount .eo-hs-card--product .eo-hs-card__body {
    padding: 0;
    min-width: 0;
    gap: 0;
  }

  .ps-rev-carousel__product-mount .eo-hs-card--product .eo-hs-card__title {
    font-size: clamp(0.8125rem, 0.32vw + 0.74rem, 0.9375rem);
    font-weight: 700;
    line-height: 1.35;
    color: var(--product-name-text, #111111);
  }

  .ps-rev-carousel__product-mount .eo-hs-card--product .eo-hs-card__meta {
    display: none;
  }

  .ps-rev-carousel__product-hs .eo-hs-error {
    margin: 0;
    font-size: 0.82rem;
    color: #8b3225;
  }

  @keyframes ps-rc-hs-shimmer {
    0% {
      background-position: 100% 0;
    }
    100% {
      background-position: -100% 0;
    }
  }

  @media (max-width: 767.98px) {
    .ps-rev-carousel-slot {
      --bs-gutter-x: 1rem;
      --ps-rc-inline-pad: max(
        14px,
        env(safe-area-inset-left, 0px),
        env(safe-area-inset-right, 0px)
      );
    }
  }

  @media (min-width: 576px) {
    .ps-rev-carousel-slot {
      max-width: 680px;
    }
  }

  @media (min-width: 768px) {
    .ps-rev-carousel-slot {
      max-width: 900px;
    }
  }

  @media (min-width: 992px) {
    .ps-rev-carousel-slot {
      max-width: 1160px;
    }
  }

  @media (min-width: 1200px) {
    .ps-rev-carousel-slot {
      max-width: 1320px;
    }
  }

  @media (min-width: 1400px) {
    .ps-rev-carousel-slot {
      max-width: 1520px;
    }
  }

  /* Hydrated host markup (testimonial row + product title link) — same palette as cards above */
  .ps-rev-carousel-shell h4.testimonial__name,
  .ps-rev-carousel-shell .testimonial__name.h5,
  .ps-rev-carousel-shell .testimonial__name {
    font-size: clamp(1rem, 0.55vw + 0.84rem, 1.125rem);
    line-height: 1.35;
    font-weight: 700;
    color: var(--product-name-text, #111111);
    -webkit-text-fill-color: var(--product-name-text, #111111);
  }

  .ps-rev-carousel-shell .testimonial__bio,
  .ps-rev-carousel-shell .testimonial__bio.text-subtext,
  .ps-rev-carousel-shell .testimonial__bio.text-sm,
  .ps-rev-carousel-shell div.testimonial__bio.text-subtext.text-sm {
    font-size: clamp(0.75rem, 0.3vw + 0.68rem, 0.9rem);
    line-height: 1.4;
    font-weight: 400;
    color: var(--body-text, #333333);
    opacity: 0.72;
  }

  .ps-rev-carousel-shell a .reversed-link,
  .ps-rev-carousel-shell .reversed-link {
    font-size: clamp(0.875rem, 0.42vw + 0.78rem, 1.0625rem);
    line-height: 1.35;
    font-weight: 700;
    color: var(--product-name-text, #111111);
    -webkit-text-fill-color: var(--product-name-text, #111111);
  }

  .ps-rev-carousel-shell .testimonial__content p,
  .ps-rev-carousel-shell .testimonial p,
  .ps-rev-carousel-shell .card__content p {
    font-size: clamp(0.875rem, 0.38vw + 0.78rem, 1rem);
    line-height: 1.55;
    font-weight: 400;
    color: var(--body-text, #333333);
  }
</style>
{% endif %}
