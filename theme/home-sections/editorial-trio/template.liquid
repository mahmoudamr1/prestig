{% if section_data.cards and section_data.cards.size > 0 %}
<section class="editorial-trio">
  <div class="editorial-trio__inner">
    {% if section_data.headline != blank %}
      <h2 class="editorial-trio__headline">{{ section_data.headline }}</h2>
    {% endif %}

    {% if section_data.subtitle != blank %}
      {% if section_data.subtitle_url != blank %}
        <a class="editorial-trio__subtitle editorial-trio__subtitle--link" href="{{ section_data.subtitle_url }}">
          {{ section_data.subtitle }}
        </a>
      {% else %}
        <p class="editorial-trio__subtitle">{{ section_data.subtitle }}</p>
      {% endif %}
    {% endif %}

    {% comment %}
      Layout parity with Sleek Shopify card-media (see theme/theme.css):
      .blocks-radius, .card-media--large .content-overlay paddings, .content-overlay--bottom-center,
      portrait ~1100/1553 aspect, pill CTA ~ .btn.btn--primary
    {% endcomment %}
    <div
      class="editorial-trio__grid"
      tabindex="0"
      role="region"
      aria-label="{{ section_data.headline | default: 'Editorial cards' | escape }}"
    >
      {% for card in section_data.cards %}
        {% assign et_label = card.title | default: card.button_label | default: 'Card' %}
        {% if card.button_url != blank %}
          <a class="editorial-trio__card-link" href="{{ card.button_url }}" aria-label="{{ et_label | escape }}">
        {% else %}
          <div class="editorial-trio__card-link editorial-trio__card-link--static" role="group" aria-label="{{ et_label | escape }}">
        {% endif %}
          <div class="editorial-trio__card{% if card.image == blank %} editorial-trio__card--no-media{% endif %}">
            {% if card.image != blank %}
              <div class="editorial-trio__media">
                <img
                  class="editorial-trio__img"
                  src="{{ card.image }}"
                  alt=""
                  width="1100"
                  height="1553"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  decoding="async"
                  draggable="false"
                />
              </div>
            {% endif %}
            <div class="editorial-trio__overlay">
              <div class="editorial-trio__overlay-inner">
                {% if card.title != blank %}
                  <h3 class="editorial-trio__title">{{ card.title }}</h3>
                {% endif %}
                {% if card.button_label != blank %}
                  {% if card.button_url != blank %}
                    <span class="editorial-trio__btn">{{ card.button_label }}</span>
                  {% else %}
                    <span class="editorial-trio__btn editorial-trio__btn--disabled">{{ card.button_label }}</span>
                  {% endif %}
                {% endif %}
              </div>
            </div>
          </div>
        {% if card.button_url != blank %}
          </a>
        {% else %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  /* Tokens aligned with theme/theme.css Sleek reference (blocks-radius, card-media--large overlay, btn--primary) */
  .editorial-trio {
    --et-blocks-radius: 2.8rem;
    --et-blocks-radius-mobile: 2rem;
    --et-overlay-py: 3rem;
    --et-overlay-px: 2rem;
    --et-btn-min-h: 4.8rem;
    --et-btn-pad-x: 3.6rem;
    --et-scroll-slide: 80vw;
    --et-scroll-gap: 12px;
    box-sizing: border-box;
    width: 100%;
    padding: 0;
    background: #ffffff;
    color: #111111;
    font-family: var(--ps-ff-primary), var(--ps-ff-ui), system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  @media (min-width: 768px) and (max-width: 1279.98px) {
    .editorial-trio {
      --et-overlay-px: 2.4rem;
      --et-overlay-py: 3rem;
    }
  }

  @media (min-width: 1280px) {
    .editorial-trio {
      --et-overlay-py: 6rem;
      --et-overlay-px: 4rem;
    }
  }

  .editorial-trio__inner {
    width: 100%;
    max-width: none;
    margin-inline: 0;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: clamp(1.25rem, 3vw, 2rem);
  }

  .editorial-trio__headline {
    margin: 0;
    max-width: 38rem;
    font-size: clamp(1.35rem, 3.2vw, 1.85rem);
    font-weight: 700;
    line-height: 1.28;
    letter-spacing: -0.02em;
    color: #111111;
  }

  .editorial-trio__subtitle {
    margin: 0;
    margin-top: -0.35rem;
    font-size: 0.9375rem;
    font-weight: 500;
    line-height: 1.5;
    color: #111111;
  }

  .editorial-trio__subtitle--link {
    display: inline-block;
    text-decoration: underline;
    text-underline-offset: 0.28em;
    text-decoration-thickness: 1px;
    color: inherit;
    transition: opacity 0.2s ease;
  }

  @media (hover: hover) {
    .editorial-trio__subtitle--link:hover {
      opacity: 0.72;
    }
  }

  /* Desktop: 3 cols · Tablet landscape-ish: 2 cols · Phone: horizontal snap scroll (~80vw slides) */
  /* يملأ عرض القسم بالكامل (يتجنب ضيق align-items: center على الشبكة) */
  .editorial-trio__grid {
    align-self: stretch;
    width: 100%;
    margin-top: clamp(0.75rem, 2vw, 1.5rem);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1.5rem, 2.4vw, 2rem);
    align-items: stretch;
    box-sizing: border-box;
    outline: none;
  }

  @media (max-width: 1023.98px) and (min-width: 768px) {
    .editorial-trio__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 767.98px) {
    .editorial-trio__grid {
      display: flex;
      flex-direction: row;
      flex-wrap: nowrap;
      gap: var(--et-scroll-gap);
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      -ms-overflow-style: none;
      margin-inline: 0;
    }

    .editorial-trio__grid::-webkit-scrollbar {
      display: none;
      width: 0;
      height: 0;
    }

    .editorial-trio__grid > .editorial-trio__card-link {
      flex: 0 0 var(--et-scroll-slide);
      width: var(--et-scroll-slide);
      max-width: var(--et-scroll-slide);
      scroll-snap-align: start;
      scroll-snap-stop: normal;
      min-width: 0;
    }

    .editorial-trio__grid:focus-visible {
      outline: 2px solid currentColor;
      outline-offset: 4px;
      border-radius: 4px;
    }

    @media (prefers-reduced-motion: reduce) {
      .editorial-trio__grid {
        scroll-behavior: auto;
      }
    }

    .editorial-trio {
      --et-overlay-py: 1.75rem;
      --et-overlay-px: 1rem;
      --et-btn-min-h: 3.6rem;
      --et-btn-pad-x: 1.35rem;
      --et-blocks-radius-mobile: 1.25rem;
    }
  }

  /* .blocks-radius + .card-media--link */
  .editorial-trio__card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: var(--et-blocks-radius-mobile);
    overflow: hidden;
    -webkit-mask-image: -webkit-radial-gradient(white, black);
    mask-image: radial-gradient(white, black);
    box-sizing: border-box;
    outline-offset: 4px;
  }

  @media (min-width: 768px) {
    .editorial-trio__card-link {
      border-radius: var(--et-blocks-radius);
    }
  }

  .editorial-trio__card-link:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 4px;
  }

  .editorial-trio__card-link--static {
    cursor: default;
  }

  /* .card-media.card-media--large.relative.overflow-hidden */
  .editorial-trio__card {
    position: relative;
    isolation: isolate;
    width: 100%;
    aspect-ratio: 1100 / 1553;
    max-height: min(720px, 92vh);
    margin: 0 auto;
    background: #f4f4f4;
    border-radius: inherit;
    overflow: hidden;
    transform: translateZ(0);
  }

  .editorial-trio__card--no-media {
    background: linear-gradient(165deg, #f5f5f5 0%, #ebe8e6 100%);
  }

  .editorial-trio__card--no-media .editorial-trio__overlay::before {
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0) 0%,
      rgba(255, 255, 255, 0.25) 100%
    );
  }

  @media (max-width: 899px) {
    .editorial-trio__card {
      max-height: none;
    }
  }

  .editorial-trio__media {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-radius: inherit;
  }

  .editorial-trio__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
    transform: scale(1.001);
    transition: transform 0.54s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @media (prefers-reduced-motion: no-preference) and (hover: hover) {
    .editorial-trio__card-link:not(.editorial-trio__card-link--static):hover .editorial-trio__img {
      transform: scale(1.06);
    }
  }

  /* .content-overlay.content-overlay--bottom-center + card-media--large paddings */
  .editorial-trio__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    padding: var(--et-overlay-py) var(--et-overlay-px);
    text-align: center;
    color: #111111;
    pointer-events: none;
    border-radius: inherit;
  }

  .editorial-trio__overlay-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(0.85rem, 2vw, 1.25rem);
    width: 100%;
    max-width: 28rem;
    pointer-events: none;
    position: relative;
    z-index: 1;
  }

  /* Legibility wash — mirrors photographic cards on demo */
  .editorial-trio__overlay::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0) 0%,
      rgba(255, 255, 255, 0.06) 38%,
      rgba(255, 255, 255, 0.55) 100%
    );
    z-index: 0;
  }

  /* .rich-text__heading.h2 — Sleek uses medium-large sans */
  .editorial-trio__title {
    margin: 0;
    font-size: clamp(1.35rem, 2.6vw, 1.75rem);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.015em;
    color: #111111;
    max-width: 22ch;
    text-wrap: balance;
  }

  /* .btn.btn--primary appearance (solid fill, pill) */
  .editorial-trio__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem var(--et-btn-pad-x);
    border-radius: 624.9375rem;
    background: #111111;
    color: #ffffff;
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: 0.01em;
    text-transform: none;
    text-decoration: none;
    border: none;
    box-sizing: border-box;
    transition: opacity 0.25s ease, transform 0.25s ease;
    cursor: inherit;
  }

  @media (max-width: 767.98px) {
    .editorial-trio__title {
      font-size: clamp(1rem, 4.2vw, 1.35rem);
      max-width: none;
      line-height: 1.22;
    }

    .editorial-trio__btn {
      font-size: 0.8125rem;
      padding-top: 0.45rem;
      padding-bottom: 0.45rem;
    }

    .editorial-trio__overlay-inner {
      gap: 0.65rem;
    }
  }

  @media (hover: hover) {
    .editorial-trio__card-link:not(.editorial-trio__card-link--static):hover .editorial-trio__btn {
      opacity: 0.92;
      transform: translateY(-1px);
    }
  }

  .editorial-trio__btn--disabled {
    opacity: 0.45;
    pointer-events: none;
  }
</style>
{% endif %}
